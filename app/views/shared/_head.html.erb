<%#
  PARTIAL: app/views/shared/_head.html.erb

  DESCRIPTION:
  Defines the global HTML <head> section shared across the application.

  RESPONSIBILITIES:
  - Configures browser and mobile metadata
  - Registers security-related Rails meta tags
  - Loads shared fonts and external libraries
  - Includes application stylesheets and JavaScript assets
  - Supports page-specific head content through `content_for`

  RENDERED PARTIALS:
  - shared/_google_fonts
  - shared/_library_imports

  CONTENT BLOCKS:
  - :title -> Allows pages to override the default browser title
  - :head  -> Allows pages to inject additional <head> content
%>

<head>
  <%# ======================================================= %>
  <%#                     1. DOCUMENT TITLE                  %>
  <%# ======================================================= %>

  <title>
    <%= content_for?(:title) ? yield(:title) : "Meta" %>
  </title>

  <%# ======================================================= %>
  <%#                    2. META CONFIGURATION               %>
  <%# ======================================================= %>

  <meta name="viewport" content="width=device-width,initial-scale=1">

  <meta
    http-equiv="content-type"
    content="text/html; charset=utf-8"
  />

  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="application-name" content="Meta">
  <meta name="mobile-web-app-capable" content="yes">

  <%# Disable Turbo automatic prefetching. %>
  <meta name="turbo-prefetch" content="false">

  <%# ======================================================= %>
  <%#                    3. SECURITY TAGS                   %>
  <%# ======================================================= %>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%# ======================================================= %>
  <%#                4. PAGE-SPECIFIC HEAD CONTENT          %>
  <%# ======================================================= %>

  <%= yield :head %>

  <%# ======================================================= %>
  <%#                     5. APPLICATION ICONS              %>
  <%# ======================================================= %>

  <%= favicon_link_tag asset_path("favicon.ico") %>

  <%# ======================================================= %>
  <%#                  6. SHARED DEPENDENCIES               %>
  <%# ======================================================= %>

  <%= render "shared/google_fonts" %>
  <%= render "shared/library_imports" %>

  <%# ======================================================= %>
  <%#                     7. APPLICATION ASSETS             %>
  <%# ======================================================= %>

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>