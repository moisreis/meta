  # Package: Meta
  #
  # Description: Loads and initializes client-side JavaScript needed by views
  #              that rely on enhanced form controls. Ensures the TomSelect
  #              component is properly attached to its corresponding input field.
  #
  # Usage:
  #   - What: Injects page-specific scripts at the bottom of the layout.
  #           Initializes TomSelect for elements that require advanced select UI.
  #   - How: Render this partial inside the main layout or inside a view that
  #          needs TomSelect active on an element with id `tom-select-it`.
  #   - Why: Keeps script initialization centralized, improves readability,
  #          avoids duplicate JavaScript blocks in multiple templates, and
  #          ensures consistent behavior across pages using the same widgets.
  %>

<!-- [Script] sidebarFilters -->
<script>
    let sidebar;
    let openBtn;
    let closeBtn;
    let filterOverlay;

    function openSidebar() {
        sidebar.classList.add('opacity-100');
        sidebar.classList.remove('opacity-0', 'pointer-events-none');
        filterOverlay.classList.remove('hidden');
    }

    function closeSidebar() {
        sidebar.classList.remove('opacity-100');
        sidebar.classList.add('opacity-0', 'pointer-events-none');
        filterOverlay.classList.add('hidden');
    }

    function setupEventListeners() {
        sidebar = document.getElementById('sidebarFilters');
        openBtn = document.getElementById('openFiltersBtn');
        closeBtn = document.getElementById('closeFiltersBtn');
        filterOverlay = document.getElementById('filterOverlay')

        if (sidebar && openBtn && closeBtn) {
            openBtn.addEventListener('click', openSidebar);
            closeBtn.addEventListener('click', closeSidebar);
        } else {
            console.error("Sidebar setup failed: One or more IDs were not found in the HTML.");
        }
    }

    document.addEventListener('DOMContentLoaded', setupEventListeners);
</script>

<!-- [Script] portfolioDropdown -->
<script>
    // Explanation:: This script watches the portfolio dropdown for changes.
    //               When a new option is picked, it updates the button's link.
    //               This prevents the user from going to the wrong portfolio.
    document.addEventListener('change', (event) => {
        if (event.target.name === 'portfolio_id') {
            const link = document.getElementById('view-portfolio-link');
            const selectedId = event.target.value;
            const baseUrl = link.dataset.baseUrl;

            if (selectedId) {
                link.href = baseUrl + selectedId;
            }
        }
    });
</script>

<!-- [Script] sidebarApplication -->
<script>
    let applicationSidebar;
    let openApplicationBtn;
    let closeApplicationBtn;
    let cancelApplicationBtn;
    let applicationOverlay;

    function openApplicationSidebar() {
        applicationSidebar.classList.add('opacity-100');
        applicationSidebar.classList.remove('opacity-0', 'pointer-events-none');
        applicationOverlay.classList.remove('hidden');
    }

    function closeApplicationSidebar() {
        applicationSidebar.classList.remove('opacity-100');
        applicationSidebar.classList.add('opacity-0', 'pointer-events-none');
        applicationOverlay.classList.add('hidden');
    }

    function setupApplicationSidebarListeners() {
        applicationSidebar = document.getElementById('sidebarApplication');
        openApplicationBtn = document.getElementById('openApplicationBtn');
        closeApplicationBtn = document.getElementById('closeApplicationBtn');
        cancelApplicationBtn = document.getElementById('cancelApplicationBtn');
        applicationOverlay = document.getElementById('applicationOverlay');

        if (applicationSidebar && openApplicationBtn && closeApplicationBtn) {
            openApplicationBtn.addEventListener('click', openApplicationSidebar);
            closeApplicationBtn.addEventListener('click', closeApplicationSidebar);
            cancelApplicationBtn.addEventListener('click', closeApplicationSidebar);
            applicationOverlay.addEventListener('click', closeApplicationSidebar);

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeApplicationSidebar();
            });
        } else {
            console.error("Application sidebar setup failed: one or more IDs were not found in the HTML.");
        }
    }

    document.addEventListener('DOMContentLoaded', setupApplicationSidebarListeners);
</script>

