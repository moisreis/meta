<%#
  PARTIAL: app/views/shared/_footer_scripts.html.erb

  DESCRIPTION:
  Loads and initializes page-level JavaScript behaviors used
  throughout the application interface.

  RESPONSIBILITIES:
  - Sidebar open/close interactions
  - Overlay synchronization
  - Escape-key sidebar dismissal
  - Portfolio link synchronization
  - Shared event listener registration

  NOTES:
  - Scripts are initialized using Turbo lifecycle events.
  - All behaviors rely on fixed DOM element identifiers.
  - Missing elements are logged to the browser console.
%>

<%# ========================================================= %>
<%#                  1. FILTER SIDEBAR                       %>
<%# ========================================================= %>

<script>
  let sidebar;
  let openBtn;
  let closeBtn;
  let filterOverlay;

  function openSidebar() {
    sidebar.classList.add('opacity-100');
    sidebar.classList.remove('opacity-0', 'pointer-events-none');

    filterOverlay.classList.remove('hidden');
  }

  function closeSidebar() {
    sidebar.classList.remove('opacity-100');
    sidebar.classList.add('opacity-0', 'pointer-events-none');

    filterOverlay.classList.add('hidden');
  }

  function setupEventListeners() {
    sidebar       = document.getElementById('sidebarFilters');
    openBtn       = document.getElementById('openFiltersBtn');
    closeBtn      = document.getElementById('closeFiltersBtn');
    filterOverlay = document.getElementById('filterOverlay');

    if (sidebar && openBtn && closeBtn) {
      openBtn.addEventListener('click', openSidebar);
      closeBtn.addEventListener('click', closeSidebar);
    } else {
      console.error(
        'Sidebar setup failed: One or more IDs were not found in the HTML.'
      );
    }
  }

  document.addEventListener('turbo:load', setupEventListeners);
</script>

<%# ========================================================= %>
<%#                2. PORTFOLIO DROPDOWN LINK               %>
<%# ========================================================= %>

<script>
  document.addEventListener('change', (event) => {
    if (event.target.name === 'portfolio_id') {
      const link       = document.getElementById('view-portfolio-link');
      const selectedId = event.target.value;
      const baseUrl    = link.dataset.baseUrl;

      if (selectedId) {
        link.href = baseUrl + selectedId;
      }
    }
  });
</script>

<%# ========================================================= %>
<%#              6. PORTFOLIO LINK SYNCHRONIZATION          %>
<%# ========================================================= %>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const portfolioSelect = document.getElementById(
      'portfolio-select'
    );

    const viewPortfolioLink = document.getElementById(
      'view-portfolio-link'
    );

    if (portfolioSelect && viewPortfolioLink) {
      portfolioSelect.addEventListener('change', function () {
        const selectedPortfolioId = this.value;

        if (selectedPortfolioId) {
          viewPortfolioLink.href =
            `/portfolios/${selectedPortfolioId}`;
        }
      });
    }
  });
</script>