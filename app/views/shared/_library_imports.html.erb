<%#
  PARTIAL: app/views/shared/_library_imports.html.erb

  DESCRIPTION:
  Loads third-party frontend libraries used throughout the application.

  RESPONSIBILITIES:
  - Registers external CSS stylesheets
  - Registers external JavaScript dependencies
  - Centralizes CDN-based library imports
  - Keeps layout-level asset loading organized

  IMPORTED LIBRARIES:
  - Tom Select
  - Flatpickr
  - Flatpickr Month Select Plugin
  - Tippy.js
%>

<%# ========================================================= %>
<%#                     1. TOM SELECT                        %>
<%# ========================================================= %>

<link
  href="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/css/tom-select.css"
  rel="stylesheet"
>

<script
  src="https://cdnjs.cloudflare.com/ajax/libs/tom-select/2.4.3/js/tom-select.complete.js"
  integrity="sha512-cv8SyZZkoW3eB3rWs0JsM/wNxKZe59+tMN8ewVIu24I1EAeBOT6lqkdty/iMxo3OJGvrFRYIrrGwM5BJqAXsYw=="
  crossorigin="anonymous"
  referrerpolicy="no-referrer"
></script>

<%# ========================================================= %>
<%#                      2. FLATPICKR                        %>
<%# ========================================================= %>

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css"
>

<script
  src="https://cdn.jsdelivr.net/npm/flatpickr"
></script>

<%# ========================================================= %>
<%#              3. FLATPICKR MONTH PLUGIN                  %>
<%# ========================================================= %>

<script
  src="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/index.js"
></script>

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/style.css"
>

<%# ========================================================= %>
<%#                        4. TIPPY.JS                       %>
<%# ========================================================= %>

<script
  src="https://unpkg.com/@popperjs/core@2/dist/umd/popper.min.js"
></script>

<script
  src="https://unpkg.com/tippy.js@6/dist/tippy-bundle.umd.js"
></script>