<%#
  PARTIAL: app/views/portfolios/_form.html.erb
  DESCRIPTION: Renders the portfolio creation and editing form, including
  portfolio identification fields and nested normative article associations.

  LOCAL VARIABLES:
  - portfolio: [Portfolio] The portfolio instance bound to the form. (required)
%>

<%# ========================================================= %>
<%#                   1. FORM INITIALIZATION                  %>
<%# ========================================================= %>

<%= form_with(model: portfolio, class: "contents") do |form| %>

  <%# ========================================================= %>
  <%#             2. PORTFOLIO IDENTIFICATION FIELDSET         %>
  <%# ========================================================= %>

  <%= render(Forms::FieldsetComponent.new(
    title: "Identificação",
    description: "Defina o nome principal para organizar sua nova carteira."
  )) do %>

    <%# ========================================================= %>
    <%#                 2a. PORTFOLIO NAME FIELD                %>
    <%# ========================================================= %>

    <%= render(Forms::InputFieldComponent.new(
      f:           form,
      name:        :name,
      label:       "Nome da carteira",
      placeholder: "Carteira de Longo Prazo",
      desc:        "Escolha um nome claro e descritivo.",
      field_type:  :text_field,
      icon_name:   "wallet"
    )) %>

    <%# ========================================================= %>
    <%#             2b. ANNUAL INTEREST RATE FIELD              %>
    <%# ========================================================= %>

    <%= render(Forms::InputFieldComponent.new(
      f:           form,
      name:        :annual_interest_rate,
      label:       "Taxa de juros anual (%)",
      placeholder: "10.00",
      desc:        "Juros anuais que compõem a meta da carteira (ex: 10.00 para 10% a.a.).",
      field_type:  :number_field,
      icon_name:   "percent",
      step:        :any
    )) %>

  <% end %>

  <%# ========================================================= %>
  <%#              3. INVESTMENT POLICY FIELDSET               %>
  <%# ========================================================= %>

  <%= render(Forms::FieldsetComponent.new(
    title: "Política de Investimento",
    description: "Selecione os artigos normativos aplicáveis e defina as metas de comparação para cada um."
  )) do %>

    <div data-controller="nested-normative-articles"
         class="flex flex-col gap-1.5">

      <%# ========================================================= %>
      <%#            3a. NESTED NORMATIVE ARTICLE ENTRIES         %>
      <%# ========================================================= %>

      <div data-nested-normative-articles-target="container"
           class="flex flex-col gap-4">

        <%= form.fields_for :portfolio_normative_articles do |pna_form| %>
          <%= render "normative_article_entry",
                     f: pna_form,
                     normative_articles: @normative_articles %>
        <% end %>

      </div>

      <%# ========================================================= %>
      <%#                3b. DYNAMIC ENTRY TEMPLATE               %>
      <%# ========================================================= %>

      <template data-nested-normative-articles-target="template"
                class="flex flex-col gap-4">

        <%= form.fields_for :portfolio_normative_articles,
                            PortfolioNormativeArticle.new,
                            child_index: "NEW_RECORD" do |pna_form| %>

          <%= render "normative_article_entry",
                     f: pna_form,
                     normative_articles: @normative_articles %>

        <% end %>

      </template>

      <%# ========================================================= %>
      <%#                 3c. ADD ENTRY ACTION BUTTON             %>
      <%# ========================================================= %>

      <button type="button"
              data-action="click->nested-normative-articles#addEntry"
              class="button button-secondary button-small button-outline w-fit flex items-center gap-2">

        <%= inline_svg_tag "icons/plus.svg" %>

        <span>Adicionar Artigo</span>
      </button>

    </div>

  <% end %>

  <%# ========================================================= %>
  <%#                 4. HIDDEN USER ASSOCIATION               %>
  <%# ========================================================= %>

  <%= form.hidden_field :user_id, value: current_user.id %>

  <%# ========================================================= %>
  <%#                     5. FORM SUBMISSION                    %>
  <%# ========================================================= %>

  <%= render(Forms::SubmitButtonComponent.new(
    builder: form,
    method:  portfolio.persisted? ? :patch : :post
  )) %>

<% end %>