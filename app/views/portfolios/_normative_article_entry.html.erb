<%#
  PARTIAL: app/views/portfolios/_normative_article_entry.html.erb

  DESCRIPTION:
  Renders a single PortfolioNormativeArticle nested-form entry
  inside the portfolio form. The entry allows the user to select
  a normative article and define portfolio-specific benchmark,
  minimum, and maximum target values associated with that article.

  BEHAVIOR:
  - The root wrapper delegates select change events to the
    nested-normative-articles Stimulus controller.
  - Target fields remain hidden until a normative article
    is selected.
  - The hidden `_destroy` field enables Rails nested-form
    soft deletion through accepts_nested_attributes_for.

  ARCHITECTURE:
  - Encapsulating the entry into its own partial allows the
    parent fieldset template to pre-render blank entries
    server-side for runtime cloning by Stimulus.
  - Shared ViewComponents are used to enforce consistent
    styling, accessibility, validation rendering, and
    interaction patterns across the application.

  LOCALS:
  - f: [ActionView::Helpers::FormBuilder]
       Nested form builder scoped to PortfolioNormativeArticle.

  - normative_articles: [Array<Array>]
       Collection of [display_name, id] option pairs used by
       the normative article select field.
%>

<%# ========================================================= %>
<%#                  1. ENTRY CONTAINER                      %>
<%# ========================================================= %>

<%# Delegates bubbled change events from nested fields to the
  # Stimulus controller responsible for toggling target inputs
  # and managing nested-form interactions.
%>
<div class="flex flex-col gap-6 p-6 border border-border rounded-base bg-background w-full"
     data-nested-normative-articles-target="entry"
     data-action="change->nested-normative-articles#onSelectChange">

  <%# ======================================================= %>
  <%#                    2. REMOVE ACTION                    %>
  <%# ======================================================= %>

  <div class="flex flex-row justify-start items-center">

    <%# Marks the nested record for destruction. Persisted
      # records receive `_destroy = 1`, while unsaved rows are
      # removed directly from the DOM by the Stimulus controller.
    %>
    <button type="button"
            class="button button-icon button-small button-danger"
            data-action="click->nested-normative-articles#removeEntry"
            title="Remover artigo">

      <%= inline_svg_tag "icons/x.svg" %>
    </button>
  </div>

  <%# ======================================================= %>
  <%#                3. ARTICLE FIELDSET                     %>
  <%# ======================================================= %>

  <%= render(
        Forms::FieldsetComponent.new(
          title: "Artigo normativo",
          description: "Selecione o artigo normativo que será aplicado a esta carteira."
        )
      ) do %>

    <%# ===================================================== %>
    <%#                  3a. ARTICLE SELECT                  %>
    <%# ===================================================== %>

    <div class="w-full">
      <%= render "partials/modules/select",
                 f: f,
                 name: :normative_article_id,
                 label: "Artigo Normativo",
                 desc: "Selecione o artigo a ser aplicado a esta carteira.",
                 options_collection: [["Escolha um artigo normativo", ""]] + normative_articles,
                 selected: f.object.normative_article_id
      %>
    </div>

  <% end %>

  <%# ======================================================= %>
  <%#                    4. TARGET FIELDS                    %>
  <%# ======================================================= %>

  <div class="<%= f.object.normative_article_id.present? ? '' : 'hidden' %> grid grid-cols-1 gap-6 sm:grid-cols-3"
       data-nested-normative-articles-target="targets">

    <%# ===================================================== %>
    <%#             4a. BENCHMARK TARGET FIELD               %>
    <%# ===================================================== %>

    <%= render(
          Forms::InputFieldComponent.new(
            f: f,
            name: :benchmark_target,
            label: "Benchmark Target",
            placeholder: "0.00",
            desc: "Meta de benchmark desta carteira.",
            field_type: :number_field,
            icon_name: "target",
            step: :any
          )
        ) %>

    <%# ===================================================== %>
    <%#              4b. MINIMUM TARGET FIELD                %>
    <%# ===================================================== %>

    <%= render(
          Forms::InputFieldComponent.new(
            f: f,
            name: :minimum_target,
            label: "Meta Mínima",
            placeholder: "0.00",
            desc: "Percentual mínimo permitido.",
            field_type: :number_field,
            icon_name: "trending-down",
            step: :any
          )
        ) %>

    <%# ===================================================== %>
    <%#              4c. MAXIMUM TARGET FIELD                %>
    <%# ===================================================== %>

    <%= render(
          Forms::InputFieldComponent.new(
            f: f,
            name: :maximum_target,
            label: "Meta Máxima",
            placeholder: "100.00",
            desc: "Percentual máximo permitido.",
            field_type: :number_field,
            icon_name: "trending-up",
            step: :any
          )
        ) %>

  </div>

  <%# ======================================================= %>
  <%#                  5. DESTROY FIELD                      %>
  <%# ======================================================= %>

  <%= f.hidden_field(
        :_destroy,
        value: "0",
        data: {
          "nested-normative-articles-target": "destroy"
        }
      ) %>

</div>
