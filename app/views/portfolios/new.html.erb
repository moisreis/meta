<%#
  VIEW: app/views/portfolios/new.html.erb
  ACTION: PortfoliosController#new

  DESCRIPTION:
  Renders the portfolio creation page using the dashboard layout
  wrapper and the shared portfolio form partial configured for
  record creation.

  INSTANCE VARIABLES:
  - @form: [ActiveModel] Form object responsible for portfolio
           creation attributes and validations.
  - @normative_articles: [Enumerable] Collection used to populate
                         normative article selection inputs.
%>

<%# ========================================================= %>
<%#                    1. DASHBOARD WRAPPER                  %>
<%# ========================================================= %>

<%= render(
      Layout::DashboardWrapperComponent.new(
        page_title: "Criar carteira",
        page_desc: "Defina os detalhes da sua nova carteira para começar a acompanhar seus investimentos."
      )
    ) do %>

  <%# ======================================================= %>
  <%#                 2. PORTFOLIO FORM PARTIAL              %>
  <%# ======================================================= %>

  <%= render(
        "form",
        portfolio: @form,
        button_name: "Criar",
        icon_name: "plus",
        normative_articles: @normative_articles
      ) %>

<% end %>
