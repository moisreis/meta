<%#
  VIEW: app/views/portfolios/show.html.erb
  ACTION: PortfoliosController#show

  INSTANCE VARIABLES:
  - @portfolio: [Portfolio] The portfolio dashboard data and associations used for the view.
  - @total_market_value: [BigDecimal] The portfolio's total market value for KPI display.
  - @reference_date: [Date] The current reference date for chart and table snapshots.
  - @reference_period: [Date] The current reference period used to label recent performance.
  - @portfolio_yearly_twr: [Numeric] The portfolio's cumulative year-to-date time-weighted return.
  - @portfolio_monthly_twr: [Numeric] The portfolio's monthly time-weighted return.
  - @portfolio_12m_return: [Numeric] The portfolio's trailing 12-month return.
  - @compliance_report: [Array<Hash>] Compliance metrics for portfolio policy articles.
  - @monthly_earnings_history: [Array<[String, Numeric]>] Monthly earnings values used by the chart.
  - @equity_evolution: [Array<[String, Numeric]>] Historical portfolio equity values used by the chart.
  - @monthly_flows: [Array<[String, Numeric]>] Monthly cash flow values used by the chart.
  - @allocation_data: [Array<Hash>] Current fund allocation values used by the allocation pie chart.
  - @indices_data: [Array<Hash>] Distribution data by benchmark index.
  - @institution_distribution: [Array<Hash>] Distribution data by financial institution.
  - @recent_performance: [Array<PerformanceHistory>] Recent fund performance records.
  - @recent_applications: [Array<Application>] Recent application transactions displayed in the APR panel.
  - @recent_redemptions: [Array<Redemption>] Recent redemption transactions displayed in the APR panel.

  TABLE OF CONTENTS:
  1.  Dashboard Wrapper
  2.  KPIs
  3.  Compliance & Legal Limits
  4.  Detailed Analysis
      4a. Monthly Earnings
      4b. Equity Evolution
      4c. Movements
  5.  Current Allocation
  6.  Diversification Analysis
      6a. By Benchmark Index
      6b. By Institution
  7.  Fund Investment List
  8.  Investment Policy
  9.  Fund Performance
  10. Checking Accounts
  11. APR Activity
      11a. Applications
      11b. Redemptions
  12. Transaction Modals
%>

<%# ========================================================= %>
<%#                    1. DASHBOARD WRAPPER                    %>
<%# ========================================================= %>

<%= render(Layout::DashboardWrapperComponent.new(
  page_title: @portfolio.name,
  page_desc: "Carteira de #{@portfolio.user.full_name}",
  current_view: "show"
)) do %>


<%# ========================================================= %>
<%#                         2. KPIs                           %>
<%# ========================================================= %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "KPIs",
      description: "Indicadores-chave de desempenho da carteira",
      columns: 4,
    )
  ) do %>  

    <%= render(
      Blocks::CardComponent.new(
        title: "Total da Carteira",
        header_icon: "banknote",
      )
    ) do %>
      <%= normalize_currency(@total_market_value) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Rendimento Acumulado do Ano",
        header_icon: "wallet",
      )
    ) do %>
      <%= normalize_currency(@portfolio.yearly_earnings) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Rendimento do Mês",
        header_icon: "wallet",
        badge_text: "Ref. #{l(@reference_date, format: :default)}",
      )
    ) do %>
      <%= normalize_trend(@portfolio.total_earnings_on(@reference_date)) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Rendimento Acumulado do Ano",
        header_icon: "wallet",
      )
    ) do %>
      <%= normalize_trend(@portfolio_yearly_twr, format: :percentage) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Rendimento do Mês",
        header_icon: "wallet",
        badge_text: "Ref. #{l(@reference_date, format: :default)}",
      )
    ) do %>
      <%= normalize_trend(@portfolio_monthly_twr, format: :percentage) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Rentabilidade dos Últimos 12 meses",
        header_icon: "trending-up",
        badge_text: "Ref. #{l(@reference_date, format: :default)}",
      )
    ) do %>
      <%= normalize_trend(@portfolio_12m_return, format: :percentage) %>
    <% end %>

  <% end %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Compliance e Limites Legais",
      description: "Comparativo entre alocação atual e limites da política de investimento.",
      columns: 1,
    )
  ) do %>

<%# ========================================================= %>
<%#               3. COMPLIANCE & LEGAL LIMITS                %>
<%# ========================================================= %>

<%= render Groups::ChartListComponent.new(
      chart_type:  :bar_chart,
      chart_title: "Enquadramento por Artigo (%)",
      palette:     :compliance,
      data_source: [
        { name: "Alocação Atual",    data: @compliance_report.map { |r| [r[:article], r[:actual]] } },
        { name: "Objetivo (Target)", data: @compliance_report.map { |r| [r[:article], r[:target]] } },
        { name: "Limite Máximo",     data: @compliance_report.map { |r| [r[:article], r[:max]] } }
      ],
      chart_options: {
        suffix: "%",
        library: {
          plugins: {
            legend: { position: "bottom" }
          }
        },
        dataset: {
          borderWidth: 0
        }
      }
    ) %>
    <% end %>

<%# ========================================================= %>
<%#                      4. DETAILED ANALYSIS                   %>
<%# ========================================================= %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Análise Detalhada",
      description: "Gráficos e tabelas para uma visão aprofundada da carteira.",
      columns: 2,
    )
  ) do %>

<%# ========================================================= %>
<%#                    4a. MONTHLY EARNINGS                     %>
<%# ========================================================= %>

<%= render Groups::ChartListComponent.new(
      chart_type:  :column_chart,
      chart_title: "Rendimento Mensal",
      palette:     nil,
      data_source: @monthly_earnings_history,
      chart_options: {
        prefix:    "R$ ",
        thousands: ".",
        decimal:   ",",
        library: {
          plugins:  { colorschemes: false },
          elements: { bar: { borderWidth: 0 } }
        },
        dataset: {
          borderWidth:     0,
          backgroundColor: @monthly_earnings_history.map { |_, v|
            v.to_f >= 0 ? ChartPalettes.rgba(:green, 0.85)
                        : ChartPalettes.rgba(:red,   0.85)
          }
        }
      }
    ) %>

<%# ========================================================= %>
<%#                   4b. EQUITY EVOLUTION                      %>
<%# ========================================================= %>

<%= render Groups::ChartListComponent.new(
      chart_type:  :column_chart,
      chart_title: "Evolução do Patrimônio",
      palette:     nil,
      data_source: @equity_evolution,
      chart_options: {
        prefix:    "R$ ",
        thousands: ".",
        decimal:   ",",
        library: {
          plugins:  { colorschemes: false },
          elements: { bar: { borderWidth: 0 } }
        },
        dataset: {
          borderWidth:     0,
          backgroundColor: @equity_evolution.map { |_, v|
            v.to_f >= 0 ? ChartPalettes.rgba(:green, 0.85)
                        : ChartPalettes.rgba(:red,   0.85)
          }
        }
      }
    ) %>

<%# ========================================================= %>
<%#                      4c. MOVEMENTS                          %>
<%# ========================================================= %>

<%= render Groups::ChartListComponent.new(
      chart_type:  :column_chart,
      chart_title: "Movimentações",
      palette:     nil,
      data_source: @monthly_flows,
      chart_options: {
        stacked:   false,
        prefix:    "R$ ",
        thousands: ".",
        decimal:   ",",
        colors:    [ChartPalettes.rgba(:green, 0.85), ChartPalettes.rgba(:red, 0.85)],
        dataset:   { borderWidth: 0 }
      }
    ) %>

  <% end %>

<%# ========================================================= %>
<%#                     5. CURRENT ALLOCATION                    %>
<%# ========================================================= %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Alocação Atual",
      description: "Visão detalhada da composição atual da carteira por fundos",
      columns: 1,
    )
  ) do %>

<%= render Groups::ChartListComponent.new(
      chart_type:  :pie_chart,
      chart_title: "Fundos alocados",
      palette:     :distribution,
      data_source: @allocation_data,
      chart_options: {
        suffix: "%",
        donut:  true,
        legend: "left"
      }
    ) %>
  <% end %>

<%# ========================================================= %>
<%#                  6. DIVERSIFICATION ANALYSIS                 %>
<%# ========================================================= %>

    <%= render(
    Blocks::SectionComponent.new(
      title: "Análise de Diversificação",
      description: "Distribuição da carteira por índices de referência e instituições financeiras para monitorar níveis de concentração.",
      columns: 2,
    )
  ) do %>

<%# ========================================================= %>
<%#              6a. BY BENCHMARK INDEX                         %>
<%# ========================================================= %>

<%= render Groups::ChartListComponent.new(
      chart_type:  :pie_chart,
      chart_title: "Distribuição por Índice",
      palette:     :distribution,
      data_source: @indices_data,
      chart_options: {
        suffix: "%",
        donut:  true,
        legend: "left"
      }
    ) %>

<%# ========================================================= %>
<%#                6b. BY INSTITUTION                           %>
<%# ========================================================= %>

<%= render Groups::ChartListComponent.new(
      chart_type:  :pie_chart,
      chart_title: "Distribuição por Instituição",
      palette:     :distribution,
      data_source: @institution_distribution,
      chart_options: {
        suffix: "%",
        donut:  true,
        legend: "left"
      }
    ) %>
  <% end %>

<%# ========================================================= %>
<%#                   7. FUND INVESTMENT LIST                     %>
<%# ========================================================= %>

<%# Displays a comprehensive list of all funds within the portfolio,
      including current valuation and periodic performance metrics. %>
<%= render(Groups::TableListComponent.new(
      title:       "Lista de fundos alocados",
      description: "Dados de #{l(@reference_date, format: :long)}",
      action:      { path: new_fund_investment_path(portfolio_id: @portfolio.id), label: "Nova alocação" },
      collection:  @portfolio.fund_investments.includes(:investment_fund, :applications, :redemptions)
    )) do |table| %>

  <% ref = l(@reference_date, format: :default) %>

  <% table.with_column(label: "Fundo",              icon: "layers",   description: nil) %>
  <% table.with_column(label: "Alocação",            icon: "shuffle",  description: nil) %>
  <% table.with_column(label: "Movimentação",        icon: "banknote", description: nil) %>
  <% table.with_column(label: "Cota mais recente",   icon: "percent",  description: ref) %>
  <% table.with_column(label: "Valor Atual",         icon: "banknote", description: ref) %>
  <% table.with_column(label: "Rendimento",          icon: nil,        description: ref) %>
  <% table.with_column(label: "Rent.",               icon: nil,        description: ref) %>

  <% @portfolio.fund_investments
               .includes(:investment_fund, :applications, :redemptions)
               .each do |fi| %>
    <% perf = @performance_by_fund[fi.id] %>
    <% table.with_row(
        model_id:     fi.id,
        show_path:    fund_investment_path(fi),
        edit_path:    edit_fund_investment_path(fi),
        destroy_path: fund_investment_path(fi),
        cells: [
          normalize_title(fi.investment_fund.fund_name),
          normalize_percentage([fi.percentage_allocation, 0].max),
          normalize_trend(fi.net_movement_on(@reference_date)),
          normalize_currency(fi.investment_fund.quota_value_on(@reference_date)),
          normalize_currency(fi.current_market_value_on(@reference_date)),
          normalize_trend(perf&.earnings,       format: :currency),
          normalize_trend(perf&.monthly_return, format: :percentage)
        ]
      ) %>
  <% end %>

<% end %>

<%# ========================================================= %>
<%#                  8. INVESTMENT POLICY                       %>
<%# ========================================================= %>

<%= render(Groups::TableListComponent.new(
      title:       "Política de Investimentos",
      description: "Metas da carteira comparadas aos limites de cada artigo.",
      collection:  @portfolio.portfolio_normative_articles.includes(:normative_article)
    )) do |table| %>

  <% table.with_column(label: "Artigo",               icon: "file-text")     %>
  <% table.with_column(label: "Categoria",             icon: "tag")           %>
  <% table.with_column(label: "Benchmark (Artigo)",    icon: "target")        %>
  <% table.with_column(label: "Benchmark (Carteira)",  icon: "target")        %>
  <% table.with_column(label: "Desvio",                icon: "activity")      %>
  <% table.with_column(label: "Mín. (Artigo)",         icon: "trending-down") %>
  <% table.with_column(label: "Mín. (Carteira)",       icon: "trending-down") %>
  <% table.with_column(label: "Máx. (Artigo)",         icon: "trending-up")   %>
  <% table.with_column(label: "Máx. (Carteira)",       icon: "trending-up")   %>

  <% @portfolio.portfolio_normative_articles.includes(:normative_article).each do |pna| %>
    <% article = pna.normative_article %>
    <% table.with_row(
        model_id: pna.id,
        cells: [
          article.display_name,
          article.category.presence || "—",
          normalize_percentage(article.benchmark_target),
          normalize_percentage(pna.benchmark_target),
          normalize_trend(pna.benchmark_deviation, format: :percentage),
          normalize_percentage(article.minimum_target),
          normalize_percentage(pna.minimum_target),
          normalize_percentage(article.maximum_target),
          normalize_percentage(pna.maximum_target)
        ]
      ) %>
  <% end %>

<% end %>

<%# ========================================================= %>
<%#                    9. FUND PERFORMANCE                      %>
<%# ========================================================= %>

<% if @recent_performance.any? %>
  <% ref_month = l(@reference_period, format: :month_year) %>

  <%= render(Groups::TableListComponent.new(
        title:      "Performance dos Fundos",
        action:     { path: "#", label: "Ver histórico" },
        collection: @recent_performance
      )) do |table| %>

    <% table.with_column(label: "Fundo",         icon: "trending-up", description: nil)       %>
    <% table.with_column(label: "Rentabilidade",  icon: "percent",     description: ref_month) %>
    <% table.with_column(label: "Rendimento",     icon: "banknote",    description: ref_month) %>

    <% @recent_performance.each do |ph| %>
      <% table.with_row(
          model_id: ph.id,
          cells: [
            normalize_title(ph.fund_investment.investment_fund.fund_name),
            normalize_trend(ph.monthly_return, format: :percentage),
            normalize_currency(ph.earnings)
          ]
        ) %>
    <% end %>

  <% end %>
<% end %>
<%# ========================================================= %>
<%#                    10. CHECKING ACCOUNTS                    %>
<%# ========================================================= %>


  <%= render "partials/groups/table-list",
             section_title: "Contas Correntes",
             collection: @portfolio.checking_accounts.order(reference_date: :desc),
             th_descs: [nil, nil, nil, nil, nil, "Por conta"],
             action_path: "javascript:void(0)",
             action_name: "Nova Conta",
             button_id: "openCheckingAccountBtn",
             action_icon: "plus",
             headers: ["Instituição", "Conta", "Saldo", "Referência"],
             column_icons: ["building", "hash", "banknote", "calendar"],
             body_procs: [
               ->(ca) { normalize_title(ca.institution.presence) },
               ->(ca) { normalize_code(ca.account_number.presence) },
               ->(ca) { normalize_currency(ca.balance) },
               ->(ca) { l(ca.reference_date, format: :long) }
             ],
             edit_path: ->(ca) { edit_portfolio_checking_account_path(@portfolio, ca) },
             show_path: ->(ca) { portfolio_checking_account_path(@portfolio, ca) },
             destroy_path: ->(ca) { portfolio_checking_account_path(@portfolio, ca) }
  %>

  <%= render "partials/route/dashboard/create_checkingaccount" %>

<%= render "partials/route/dashboard/section",
             columns: 2,
             section_title: "APR",
             section_desc: "Autorização de Aplicação e Resgate",
             has_action: false do
  %>

    <%# Lists the five most recent investment applications made within
        the current year to provide a quick operational summary. %>
    <%= render "partials/groups/recent_activity",
               section_title: "Aplicações",
               section_columns: 1,
               has_action: true,
               button_route: "javascript:void(0)",
               button_name: "Nova Aplicação",
               button_id: "openApplicationBtn",
               button_icon: "plus",
               collection: @portfolio.fund_investments
                                     .includes(:applications)
                                     .flat_map(&:applications)
                                     .select { |app| app.request_date&.year == Date.current.year }
                                     .sort_by(&:request_date)
                                     .reverse
                                     .first(5),
               color: "success",
               see_all_path: applications_path(q: { fund_investment_portfolio_id_eq: @portfolio.id }),
               title_proc: ->(app) { app.fund_investment.investment_fund.fund_name },
               value_proc: ->(app) { normalize_currency(app.financial_value) },
               sub_value_proc: ->(app) {
                 content_tag(
                   :span,
                   "#{strip_tags(normalize_number(app.number_of_quotas))} cotas",
                   style: "white-space: nowrap;"
                 )
               }
    %>
    <%# Displays the five most recent redemption requests to track
        the liquidation history of assets during the year. %>
    <%= render "partials/groups/recent_activity",
               section_title: "Resgates",
               section_columns: 1,
               has_action: true,
               button_route: "javascript:void(0)",
               button_name: "Novo Resgate",
               button_icon: "minus",
               button_id: "openRedemptionBtn",
               collection: @portfolio.fund_investments
                                     .includes(:redemptions)
                                     .flat_map(&:redemptions)
                                     .select { |red| red.request_date&.year == Date.current.year }
                                     .sort_by(&:request_date)
                                     .reverse
                                     .first(5),
               color: "danger",
               see_all_path: redemptions_path(q: { fund_investment_portfolio_id_eq: @portfolio.id }),
               title_proc: ->(red) { red.fund_investment.investment_fund.fund_name },
               value_proc: ->(red) { normalize_currency(red.redeemed_liquid_value) },
               sub_value_proc: ->(red) {
                 content_tag(:span,
                             "#{strip_tags(normalize_number(red.redeemed_quotas))} cotas",
                             style: "white-space: nowrap;"
                 )
               }
    %>
  <% end %>

  <%# =============================================================
    # Transaction Modals
    # ============================================================= %>

  <%# Injects the hidden modals required to record new application
      and redemption transactions directly from the dashboard. %>
  <%= render "partials/route/dashboard/create_application" %>
  <%= render "partials/route/dashboard/create_redemption" %>

<% end %>
