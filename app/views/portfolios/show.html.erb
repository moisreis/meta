<%#
  # Partial: show.html.erb
  # Date: 2025-12-03
  # Author: Moisés Reis
  # Package: Meta
  #
  # Description: Displays the detailed dashboard view for a single investment portfolio.
  # This template organizes financial KPIs, performance charts, and asset lists
  # into a cohesive analytical interface for the user.
  #
  # Locals:
  # @param [Portfolio]          @portfolio               - The portfolio instance being displayed.
  # @param [Date]               @reference_date          - The specific date chosen for data filtering.
  # @param [Date]               @reference_period        - The end-of-month date for the selected period.
  # @param [BigDecimal]         @total_market_value      - Calculated market value at the reference date.
  # @param [BigDecimal]         @total_earnings          - Monthly earnings from active funds.
  # @param [BigDecimal]         @portfolio_return        - The weighted monthly return percentage.
  # @param [BigDecimal]         @portfolio_12m_return    - Return percentage over the last twelve months.
  # @param [BigDecimal]         @portfolio_yearly_return - Accumulated return percentage for the current year.
  # @param [Hash]               @performance_by_fund     - Performance history mapped by fund investment ID.
  # @param [ActiveRecord::Rel]  @recent_performance      - Collection of recent performance records.
  #
  # Notes:
  # Uses the +Portfolio+ model and relies on +PerformanceHistory+ for analytical data.
  # Includes interactive forms that connect to +ReferenceDateController+ for filtering.
%>
<%= render 'partials/route/dashboard/wrapper',
           page_title: @portfolio.name,
           page_desc: "Carteira de #{@portfolio.user.full_name}",
           current_view: "show" do
%>

  <%# =============================================================
    # Key Performance Indicators (KPIs)
    # ============================================================= %>

  <%= render "partials/route/dashboard/section",
             section_title: "KPIs",
             columns: 4 do
  %>

    <%# Displays the total reconstructed market value for the portfolio
        as it existed on the specific reference date. %>
    <%= render(
          "partials/route/dashboard/card",
          card_title: "Total da Carteira",
          card_icon: "banknote"
        ) do
    %>
      <%= normalize_currency(@total_market_value) %>
    <% end %>

    <%# Shows the total financial earnings accumulated since the
        beginning of the current calendar year. %>
    <%= render(
          "partials/route/dashboard/card",
          card_title: "Rendimento Acumulado do Ano",
          card_icon: "wallet",
          status: card_status_trend_for(@portfolio.yearly_earnings)
        ) do
    %>
      <%= normalize_currency(@portfolio.yearly_earnings) %>
    <% end %>

<%# Presents the actual financial earnings for the month
    associated with the current reference date. %>
    <%= render(
          "partials/route/dashboard/card",
          card_title: "Rendimento do Mês",
          card_icon: "wallet",
          card_data: "Ref. #{l(@reference_date, format: :default)}",
          status: card_status_trend_for(@portfolio.total_earnings_on(@reference_date))
        ) do %>
      <%= normalize_trend(@portfolio.total_earnings_on(@reference_date)) %>
    <% end %>

    <%# Displays the percentage return achieved by the portfolio
        across the current calendar year. %>
    <%= render(
            "partials/route/dashboard/card",
          card_title: "Rendimento Acumulado do Ano",
          card_icon: "wallet",
          status: card_status_trend_for(@portfolio_yearly_twr)
        ) do %>
      <%= normalize_trend(@portfolio_yearly_twr, format: :percentage) %>
    <% end %>

    <%# Shows the percentage return specific to the month of the
        currently selected reference date. %>
    <%= render(
          "partials/route/dashboard/card",
          card_title: "Rendimento do Mês",
          card_icon: "wallet",
          card_data: "Ref. #{l(@reference_date, format: :default)}",
          status: card_status_trend_for(@portfolio_monthly_twr)
        ) do %>
      <%= normalize_trend(@portfolio_monthly_twr, format: :percentage) %>
    <% end %>

    <%# Provides the trailing twelve-month percentage return for the
        portfolio, indicating long-term performance. %>
    <%= render(
          "partials/route/dashboard/card",
          card_title: "Rentabilidade dos Últimos 12 meses",
          card_icon: "trending-up",
          card_data: normalize_card_time_ago(@reference_period),
          status: card_status_trend_for(@portfolio_12m_return)
        ) do
    %>
      <%= normalize_trend(@portfolio_12m_return, format: :percentage) %>
    <% end %>

  <% end %>

  <%# =============================================================
    # Analytical Charts & Visualizations
    # ============================================================= %>

    <%= render "partials/route/dashboard/section",
               section_title: "Compliance e Limites Legais",
               section_desc: "Comparativo entre alocação atual e limites da política de investimento.",
               columns: 1 do %>

      <%= render "partials/groups/chart-list",
                 chart_type: :bar_chart,
                 data_source: [
                   { name: "Alocação Atual", data: @compliance_report.map { |r| [r[:article], r[:actual]] } },
                   { name: "Objetivo (Target)", data: @compliance_report.map { |r| [r[:article], r[:target]] } },
                   { name: "Limite Máximo", data: @compliance_report.map { |r| [r[:article], r[:max]] } }
                 ],
                 chart_title: "Enquadramento por Artigo (%)",
                 chart_options: {
                   suffix: "%",
                   colors: ["rgb(109, 40, 217)", "rgb(34, 120, 87)", "rgb(17, 94, 89)"],
                   library: {
                     plugins: {
                       legend: { position: 'bottom' }
                     }
                   },
                   dataset: {
                     borderWidth: 0,
                   }
                 }
      %>
    <% end %>

  <%= render "partials/route/dashboard/section",
             section_title: "Análise Detalhada",
             columns: 2 do
  %>

    <%# Visualizes historical monthly earnings using a color-coded
        column chart to highlight gains and losses. %>
    <%= render "partials/groups/chart-list",
               chart_type: :column_chart,
               data_source: @monthly_earnings_history,
               chart_title: "Rendimento Mensal",
               chart_options: {
                 prefix: "R$ ", thousands: ".", decimal: ",",
                 library: { plugins: { colorschemes: false }, elements: { bar: { borderWidth: 0 } } },
                 dataset: {
                   borderWidth: 0,
                   backgroundColor: @monthly_earnings_history.map { |_, v|
                     v.to_f >= 0 ? "rgba(34, 120, 87, 0.85)" : "rgba(185, 28, 28, 0.85)"
                   }
                 }
               }
    %>

    <%# Displays the growth of total portfolio equity over time,
        allowing the user to track wealth accumulation. %>
    <%= render "partials/groups/chart-list",
               chart_type: :column_chart,
               data_source: @equity_evolution,
               chart_title: "Evolução do Patrimônio",
               chart_options: {
                 prefix: "R$ ", thousands: ".", decimal: ",",
                 library: { plugins: { colorschemes: false }, elements: { bar: { borderWidth: 0 } } },
                 dataset: {
                   borderWidth: 0,
                   backgroundColor: @equity_evolution.map { |_, v|
                     v.to_f >= 0 ? "rgba(34, 120, 87, 0.85)" : "rgba(185, 28, 28, 0.85)"
                   }
                 }
               }
    %>

    <%# Illustrates inflows and outflows within the portfolio,
        differentiating between applications and redemptions. %>
    <%= render "partials/groups/chart-list",
               chart_type: :column_chart,
               data_source: @monthly_flows,
               chart_title: "Movimentações",
               chart_options: {
                 stacked: false, prefix: "R$ ", thousands: ".", decimal: ",",
                 colors: ["rgba(34, 120, 87, 0.85)", "rgba(185, 28, 28, 0.85)"],
                 dataset: { borderWidth: 0 }
               }
    %>

  <% end %>

  <%# =============================================================
    # Asset Allocation & Transaction Visuals
    # ============================================================= %>
  <%= render "partials/route/dashboard/section",
             section_title: "Visualizações",
             columns: 1 do
  %>
    <%# Breaks down the portfolio by individual funds to show
        the percentage of capital allocated to each. %>
    <%= render "partials/groups/chart-list",
               chart_type: :pie_chart,
               data_source: @allocation_data,
               chart_title: "Fundos alocados",
               chart_options: { suffix: "%", donut: true, legend: "left" }
    %>
  <% end %>
  <%= render "partials/route/dashboard/section",
             section_title: "Visualizações",
             columns: 2 do
  %>

    <%# Breaks down the portfolio by benchmark indices to show
    the percentage of capital allocated to each economic driver. %>
    <%= render "partials/groups/chart-list",
               chart_type: :pie_chart,
               data_source: @indices_data,
               chart_title: "Distribuição por Índice",
               chart_options: {
                 suffix: "%",
                 donut: true,
                 legend: "left"
               }
    %>

    <%# Shows the distribution of assets across different financial
        institutions to monitor diversification levels. %>
    <%= render "partials/groups/chart-list",
               chart_type: :pie_chart,
               data_source: @institution_distribution,
               chart_title: "Distribuição por Instituição",
               chart_options: { donut: true, legend: "left", suffix: "%" }
    %>
  <% end %>

  <%# =============================================================
    # Fund Investment & Performance Tables
    # ============================================================= %>

  <%# Displays a comprehensive list of all funds within the portfolio,
      including current valuation and periodic performance metrics. %>
  <%= render "partials/groups/table-list",
             section_title: "Lista de fundos alocados",
             section_desc: "Dados de #{l(@reference_date, format: :long)}",
             th_descs: Array.new(3, nil) + Array.new(4, "Ref. #{l(@reference_date, format: :default)}"),
             collection: @portfolio.fund_investments.includes(:investment_fund, :applications, :redemptions),
             action_path: new_fund_investment_path(portfolio_id: @portfolio.id),
             action_name: "Nova alocação",
             headers: [
               "Fundo",
               "Alocação",
               "Movimentação",
               "Cota mais recente",
               "Valor Atual",
               "Rendimento",
               "Rent."
             ],
             column_icons: ["layers", "shuffle", "banknote", "percent", "banknote"],
             body_procs: [
               ->(fi) { normalize_title(fi.investment_fund.fund_name) },
               ->(fi) { normalize_percentage([fi.percentage_allocation, 0].max) },
               ->(fi) { normalize_trend(fi.net_movement_on(@reference_date)) },
               ->(fi) { normalize_currency(fi.investment_fund.quota_value_on(@reference_date)) },
               ->(fi) { normalize_currency(fi.current_market_value_on(@reference_date)) },
               ->(fi) { normalize_trend(@performance_by_fund[fi.id]&.earnings, format: :currency) },
               ->(fi) { normalize_trend(@performance_by_fund[fi.id]&.monthly_return, format: :percentage) }
             ] %>

  <%= render "partials/groups/table-list",
             section_title: "Política de Investimentos",
             section_desc: "Metas da carteira comparadas aos limites de cada artigo.",
             collection: @portfolio.portfolio_normative_articles.includes(:normative_article),
             action_path: nil,
             action_name: nil,
             headers: [
               "Artigo",
               "Categoria",
               "Benchmark (Artigo)",
               "Benchmark (Carteira)",
               "Desvio",
               "Mín. (Artigo)",
               "Mín. (Carteira)",
               "Máx. (Artigo)",
               "Máx. (Carteira)"
             ],
             column_icons: ["file-text", "tag", "target", "target", "activity", "trending-down", "trending-down", "trending-up", "trending-up"],
             body_procs: [
               ->(pna) { pna.normative_article.display_name },
               ->(pna) { pna.normative_article.category.presence || "—" },
               ->(pna) { normalize_percentage(pna.normative_article.benchmark_target) },
               ->(pna) { normalize_percentage(pna.benchmark_target) },
               ->(pna) { normalize_trend(pna.benchmark_deviation, format: :percentage) },
               ->(pna) { normalize_percentage(pna.normative_article.minimum_target) },
               ->(pna) { normalize_percentage(pna.minimum_target) },
               ->(pna) { normalize_percentage(pna.normative_article.maximum_target) },
               ->(pna) { normalize_percentage(pna.maximum_target) }
             ] %>

  <% if @recent_performance.any? %>

    <%# Renders a secondary table focusing on the performance results
        recorded for each fund during the selected period. %>
    <%= render(
          "partials/groups/table-list",
          section_title: "Performance dos Fundos",
          collection: @recent_performance,
          th_descs: [nil] + Array.new(2, "#{l(@reference_period, format: :month_year)}"),
          action_path: "#",
          action_name: "Ver histórico",
          headers: ["Fundo", "Rentabilidade", "Rendimento"],
          column_icons: ["trending-up", "percent", "banknote"],
          body_procs: [
            ->(ph) { normalize_title(ph.fund_investment.investment_fund.fund_name) },
            ->(ph) { normalize_trend(ph.monthly_return, format: :percentage) },
            ->(ph) { normalize_currency(ph.earnings) },
          ]
        ) %>
  <% end %>

  <%# =============================================================
    # Cash Management (Checking Accounts)
    # ============================================================= %>

  <%# Lists the liquid cash positions in checking accounts linked
        to the portfolio, including balances and institutions. %>
  <%= render "partials/groups/table-list",
             section_title: "Contas Correntes",
             collection: @portfolio.checking_accounts.order(reference_date: :desc),
             th_descs: [nil, nil, nil, nil, nil, "Por conta"],
             action_path: "javascript:void(0)",
             action_name: "Nova Conta",
             button_id: "openCheckingAccountBtn",
             action_icon: "plus",
             headers: ["Instituição", "Conta", "Saldo", "Referência"],
             column_icons: ["building", "hash", "banknote", "calendar"],
             body_procs: [
               ->(ca) { normalize_title(ca.institution.presence) },
               ->(ca) { normalize_code(ca.account_number.presence) },
               ->(ca) { normalize_currency(ca.balance) },
               ->(ca) { l(ca.reference_date, format: :long) }
             ],
             edit_path: ->(ca) { edit_portfolio_checking_account_path(@portfolio, ca) },
             show_path: ->(ca) { portfolio_checking_account_path(@portfolio, ca) },
             destroy_path: ->(ca) { portfolio_checking_account_path(@portfolio, ca) }
  %>

  <%# Renders the modal used to create and associate new checking
      accounts with the current portfolio instance. %>
  <%= render "partials/route/dashboard/create_checkingaccount" %>

  <%# =============================================================
    # Recent Activity (Applications & Redemptions)
    # ============================================================= %>

  <%= render "partials/route/dashboard/section",
             columns: 2,
             section_title: "APR",
             section_desc: "Autorização de Aplicação e Resgate",
             has_action: false do
  %>

    <%# Lists the five most recent investment applications made within
        the current year to provide a quick operational summary. %>
    <%= render "partials/groups/recent_activity",
               section_title: "Aplicações",
               section_columns: 1,
               has_action: true,
               button_route: "javascript:void(0)",
               button_name: "Nova Aplicação",
               button_id: "openApplicationBtn",
               button_icon: "plus",
               collection: @portfolio.fund_investments
                                     .includes(:applications)
                                     .flat_map(&:applications)
                                     .select { |app| app.request_date&.year == Date.current.year }
                                     .sort_by(&:request_date)
                                     .reverse
                                     .first(5),
               color: "success",
               see_all_path: applications_path(q: { fund_investment_portfolio_id_eq: @portfolio.id }),
               title_proc: ->(app) { app.fund_investment.investment_fund.fund_name },
               value_proc: ->(app) { normalize_currency(app.financial_value) },
               sub_value_proc: ->(app) {
                 content_tag(
                   :span,
                   "#{strip_tags(normalize_number(app.number_of_quotas))} cotas",
                   style: "white-space: nowrap;"
                 )
               }
    %>
    <%# Displays the five most recent redemption requests to track
        the liquidation history of assets during the year. %>
    <%= render "partials/groups/recent_activity",
               section_title: "Resgates",
               section_columns: 1,
               has_action: true,
               button_route: "javascript:void(0)",
               button_name: "Novo Resgate",
               button_icon: "minus",
               button_id: "openRedemptionBtn",
               collection: @portfolio.fund_investments
                                     .includes(:redemptions)
                                     .flat_map(&:redemptions)
                                     .select { |red| red.request_date&.year == Date.current.year }
                                     .sort_by(&:request_date)
                                     .reverse
                                     .first(5),
               color: "danger",
               see_all_path: redemptions_path(q: { fund_investment_portfolio_id_eq: @portfolio.id }),
               title_proc: ->(red) { red.fund_investment.investment_fund.fund_name },
               value_proc: ->(red) { normalize_currency(red.redeemed_liquid_value) },
               sub_value_proc: ->(red) {
                 content_tag(:span,
                             "#{strip_tags(normalize_number(red.redeemed_quotas))} cotas",
                             style: "white-space: nowrap;"
                 )
               }
    %>
  <% end %>

  <%# =============================================================
    # Transaction Modals
    # ============================================================= %>

  <%# Injects the hidden modals required to record new application
      and redemption transactions directly from the dashboard. %>
  <%= render "partials/route/dashboard/create_application" %>
  <%= render "partials/route/dashboard/create_redemption" %>

<% end %>
