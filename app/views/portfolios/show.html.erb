<%= render(Layout::DashboardWrapperComponent.new(
  page_title: @portfolio.name,
  page_desc: "Carteira de #{@portfolio.user.full_name}",
  current_view: "show"
)) do %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "KPIs",
      description: "Indicadores-chave de desempenho da carteira",
      columns: 4,
    )
  ) do %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Total da Carteira",
        header_icon: "banknote",
      )
    ) do %>
      <%= normalize_currency(@data.total_market_value) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Rendimento Acumulado do Ano",
        header_icon: "wallet",
      )
    ) do %>
      <%= normalize_currency(@data.yearly_earnings) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Rendimento do Mês",
        header_icon: "wallet",
        badge_text: "Ref. #{l(@reference_date, format: :default)}",
      )
    ) do %>
      <%= normalize_trend(@data.total_earnings) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Rendimento Acumulado do Ano",
        header_icon: "wallet",
      )
    ) do %>
      <%= normalize_trend(@data.portfolio_yearly_twr, format: :percentage) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Rendimento do Mês",
        header_icon: "wallet",
        badge_text: "Ref. #{l(@reference_date, format: :default)}",
      )
    ) do %>
      <%= normalize_trend(@data.portfolio_monthly_twr, format: :percentage) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Rentabilidade dos Últimos 12 meses",
        header_icon: "trending-up",
        badge_text: "Ref. #{l(@reference_date, format: :default)}",
      )
    ) do %>
      <%= normalize_trend(@data.portfolio_12m_return, format: :percentage) %>
    <% end %>

  <% end %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Compliance e Limites Legais",
      description: "Comparativo entre alocação atual e limites da política de investimento.",
      columns: 1,
    )
  ) do %>

    <%= render Groups::ChartListComponent.new(
      chart_type:  :bar_chart,
      chart_title: "Enquadramento por Artigo (%)",
      palette:     :compliance,
      data_source: Portfolios::ComplianceChartDataBuilder.call(
        @data.compliance_report
      ),
      chart_options: Charts::BarChartOptionsBuilder.call
    ) %>

  <% end %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Análise Detalhada",
      description: "Gráficos e tabelas para uma visão aprofundada da carteira.",
      columns: 2,
    )
  ) do %>

    <%= render Groups::ChartListComponent.new(
      chart_type:  :column_chart,
      chart_title: "Rendimento Mensal",
      palette:     nil,
      data_source: @data.monthly_earnings_history,
      chart_options: Charts::ConditionalColumnChartOptionsBuilder.call(
        @data.monthly_earnings_history
      )
    ) %>

    <%= render Groups::ChartListComponent.new(
      chart_type:  :column_chart,
      chart_title: "Evolução do Patrimônio",
      palette:     nil,
      data_source: @data.equity_evolution,
      chart_options: Charts::ConditionalColumnChartOptionsBuilder.call(
        @data.equity_evolution
      )
    ) %>

  <% end %>

    <%= render(
    Blocks::SectionComponent.new(
      title: "Movimentações Mensais",
      description: "Gráfico detalhado das entradas e saídas mensais",
      columns: 1,
    )
  ) do %>

    <%= render Groups::ChartListComponent.new(
      chart_type:  :column_chart,
      chart_title: "Movimentações",
      palette:     nil,
      data_source: @data.monthly_flows,
      chart_options: Charts::GroupedColumnChartOptionsBuilder.call(
        @data.monthly_flows
      )
    ) %>

  <% end %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Alocação Atual",
      description: "Visão detalhada da composição atual da carteira por fundos",
      columns: 1,
    )
  ) do %>

    <%= render Groups::ChartListComponent.new(
      chart_type:  :pie_chart,
      chart_title: "Fundos alocados",
      palette:     :distribution,
      data_source: @data.allocation_data,
      chart_options: Charts::PieChartOptionsBuilder.call(
        @data.allocation_data
      )
    ) %>

  <% end %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Análise de Diversificação",
      description: "Distribuição da carteira por índices de referência e instituições financeiras",
      columns: 2,
    )
  ) do %>

    <%= render Groups::ChartListComponent.new(
      chart_type:  :pie_chart,
      chart_title: "Distribuição por Índice",
      palette:     :distribution,
      data_source: @data.indices_data,
      chart_options: Charts::PieChartOptionsBuilder.call(
        @data.indices_data
      )
    ) %>

    <%= render Groups::ChartListComponent.new(
      chart_type:  :pie_chart,
      chart_title: "Distribuição por Instituição",
      palette:     :distribution,
      data_source: @data.institution_distribution,
      chart_options: Charts::PieChartOptionsBuilder.call(
        @data.institution_distribution
      )
    ) %>

  <% end %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Carteira vs Benchmarks",
      description: "Comparativo da evolução da carteira em relação aos principais índices de referência",
      columns: 1,
    )
  ) do %>  

    <%= render Groups::ChartListComponent.new(
      chart_type:    :line_chart,
      chart_title:   "Carteira vs Benchmarks",
      palette:       :line_series,
      data_source:   @data.benchmark_comparison_series,
      chart_options: Charts::LineSeriesChartOptionsBuilder.call(@data.benchmark_comparison_series)
    ) %>

  <% end %>
  <%= render(Groups::TableListComponent.new(
      title:       "Lista de fundos alocados",
      description: "Dados de #{l(@reference_date, format: :long)}",
      collection:  @data.fund_investments
    )) do |table| %>

    <% table.with_column(label: "Fundo",             icon: nil,   description: nil) %>
    <% table.with_column(label: "Alocação",          icon: nil,   description: nil) %>
    <% table.with_column(label: "Movimentação",      icon: nil,   description: nil) %>
    <% table.with_column(label: "Cota mais recente", icon: nil,   description: l(@reference_date, format: :default)) %>
    <% table.with_column(label: "Valor Atual",       icon: nil,   description: l(@reference_date, format: :default)) %>
    <% table.with_column(label: "Rendimento",        icon: nil,   description: l(@reference_date, format: :default)) %>
    <% table.with_column(label: "Rent.",             icon: nil,   description: l(@reference_date, format: :default)) %>

    <% @data.fund_investments.each do |fi| %>
    
      <% table.with_row(
        model_id:     fi.id,
        show_path:    fund_investment_path(fi),
        edit_path:    edit_fund_investment_path(fi),
        destroy_path: fund_investment_path(fi),
        cells: [
          normalize_title(fi.investment_fund.fund_name),
          normalize_percentage([fi.percentage_allocation, 0].max),
          normalize_trend(@data.net_movement_by_fund[fi.id], format: :currency),
          normalize_currency(@data.fund_quota_value[fi.id]),
          normalize_currency(@data.market_value_by_fund[fi.id]),
          normalize_trend(@data.performance_by_fund[fi.id]&.earnings,       format: :currency),
          normalize_trend(@data.performance_by_fund[fi.id]&.monthly_return, format: :percentage)
        ]
      ) %>

    <% end %>

  <% end %>

  <%= render(Groups::TableListComponent.new(
      title:       "Política de Investimentos",
      description: "Metas da carteira comparadas aos limites de cada artigo.",
      collection:  @data.normative_articles
    )) do |table| %>

    <% table.with_column(label: "Artigo",               icon: nil) %>
    <% table.with_column(label: "Categoria",            icon: nil) %>
    <% table.with_column(label: "Benchmark",   icon: nil, description: "Artigo") %>
    <% table.with_column(label: "Benchmark", icon: nil, description: "Carteira") %>
    <% table.with_column(label: "Desvio",               icon: nil) %>
    <% table.with_column(label: "Mín.",        icon: nil, description: "Artigo") %>
    <% table.with_column(label: "Mín.",      icon: nil, description: "Carteira") %>
    <% table.with_column(label: "Máx.",        icon: nil, description: "Artigo") %>
    <% table.with_column(label: "Máx.",      icon: nil, description: "Carteira") %>

    <% @data.normative_articles.each do |pna| %>

      <% table.with_row(
        model_id: pna.id,
        cells: [
          normalize_title(NormativeArticlesPresenter.new(pna.normative_article)),
          normalize_text(pna.normative_article.category),
          normalize_percentage(pna.normative_article.benchmark_target),
          normalize_percentage(pna.benchmark_target),
          normalize_trend(@data.benchmark_deviation_by_pna[pna.id], format: :percentage),
          normalize_percentage(pna.normative_article.minimum_target),
          normalize_percentage(pna.minimum_target),
          normalize_percentage(pna.normative_article.maximum_target),
          normalize_percentage(pna.maximum_target)
        ]
      ) %>

    <% end %>

  <% end %>

  <% if @data.recent_performance.any? %>

    <%= render(Groups::TableListComponent.new(
      title:      "Performance dos Fundos",
      collection: @data.recent_performance
    )) do |table| %>

      <% table.with_column(label: "Fundo",         icon: nil,  description: nil) %>
      <% table.with_column(label: "Rentabilidade", icon: nil,  description: l(@reference_period, format: :month_year)) %>
      <% table.with_column(label: "Rendimento",    icon: nil,  description: l(@reference_period, format: :month_year)) %>

      <% @data.recent_performance.each do |ph| %>

        <% table.with_row(
          model_id: ph.id,
          cells: [
            normalize_title(ph.fund_investment.investment_fund.fund_name),
            normalize_trend(ph.monthly_return, format: :percentage),
            normalize_currency(ph.earnings)
          ]
        ) %>

      <% end %>

    <% end %>

  <% end %>

  <%= render(Groups::TableListComponent.new(
      title:      "Contas Correntes",
      collection: @data.checking_accounts,
    )) do |table| %>

    <% table.with_column(label: "Instituição", icon: "building") %>
    <% table.with_column(label: "Conta",       icon: "hash") %>
    <% table.with_column(label: "Saldo",       icon: "banknote") %>
    <% table.with_column(label: "Referência",  icon: "calendar") %>

    <% @data.checking_accounts.each do |ca| %>

      <% table.with_row(
        model_id:     ca.id,
        cells: [
          normalize_title(ca.institution.presence),
          normalize_code(ca.account_number.presence),
          normalize_currency(ca.balance),
          l(ca.reference_date, format: :long)
        ],
        edit_path:    edit_portfolio_checking_account_path(@portfolio, ca),
        show_path:    portfolio_checking_account_path(@portfolio, ca),
        destroy_path: portfolio_checking_account_path(@portfolio, ca)
      ) %>

    <% end %>

  <% end %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "APR",
      description: "Autorização de Aplicação e Resgate",
      columns: 2,
      separator: :vertical
    )
  ) do %>  

    <%= render "partials/groups/recent_activity",
               section_title: "Aplicações",
               section_columns: 1,
               has_action: true,
               button_route: "javascript:void(0)",
               button_name: "Nova Aplicação",
               button_id: "openApplicationBtn",
               button_icon: "plus",
               collection: @portfolio.fund_investments
                                     .includes(:applications)
                                     .flat_map(&:applications)
                                     .select { |app| app.request_date&.year == Date.current.year }
                                     .sort_by(&:request_date)
                                     .reverse
                                     .first(5),
               color: "success",
               see_all_path: applications_path(q: { fund_investment_portfolio_id_eq: @portfolio.id }),
               title_proc: ->(app) { app.fund_investment.investment_fund.fund_name },
               value_proc: ->(app) { normalize_currency(app.financial_value) },
               sub_value_proc: ->(app) {
                 content_tag(
                   :span,
                   "#{strip_tags(normalize_number(app.number_of_quotas))} cotas",
                   style: "white-space: nowrap;"
                 )
               }
    %>

    <%= render "partials/groups/recent_activity",
               section_title: "Resgates",
               section_columns: 1,
               has_action: true,
               button_route: "javascript:void(0)",
               button_name: "Novo Resgate",
               button_icon: "minus",
               button_id: "openRedemptionBtn",
               collection: @portfolio.fund_investments
                                     .includes(:redemptions)
                                     .flat_map(&:redemptions)
                                     .select { |red| red.request_date&.year == Date.current.year }
                                     .sort_by(&:request_date)
                                     .reverse
                                     .first(5),
               color: "danger",
               see_all_path: redemptions_path(q: { fund_investment_portfolio_id_eq: @portfolio.id }),
               title_proc: ->(red) { red.fund_investment.investment_fund.fund_name },
               value_proc: ->(red) { normalize_currency(red.redeemed_liquid_value) },
               sub_value_proc: ->(red) {
                 content_tag(
                   :span,
                   "#{strip_tags(normalize_number(red.redeemed_quotas))} cotas",
                   style: "white-space: nowrap;"
                 )
               }
    %>

  <% end %>

  <%= render "partials/route/dashboard/create_checkingaccount" %>
  <%= render "partials/route/dashboard/create_application" %>
  <%= render "partials/route/dashboard/create_redemption" %>

<% end %>