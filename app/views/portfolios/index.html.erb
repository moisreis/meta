<%#
  VIEW: app/views/portfolios/index.html.erb
  ACTION: PortfoliosController#index

  DESCRIPTION:
  Displays the portfolio listing page with searchable,
  filterable, sortable, and paginated records using
  reusable dashboard and table components.

  INSTANCE VARIABLES:
  - @portfolios: [ActiveRecord::Relation<Portfolio>]
    Paginated portfolio collection.

  - @q: [Ransack::Search]
    Search object used for filtering and sorting.

  - @total_items: [Integer]
    Total filtered portfolio count.
%>

<%# ========================================================= %>
<%#                    1. DASHBOARD WRAPPER                  %>
<%# ========================================================= %>

<%= render(
      Layout::DashboardWrapperComponent.new(
        page_title:   "Lista de carteiras",
        page_desc:    "Lista de carteiras com permissão de visualização.",
        current_view: "datatable"
      )
    ) do %>

  <%# ======================================================= %>
  <%#                 2. PORTFOLIOS DATA TABLE               %>
  <%# ======================================================= %>

  <%= render(
        Groups::DataTableComponent.new(
          columns: [
            { label: "Nome",             icon: "wallet" },
            { label: "Proprietário",     icon: "user" },
            { label: "Valor investido",  icon: "badge-dollar-sign" },
            { label: "Cotas",            icon: "percent" }
          ],
          rows:           @portfolios,
          turbo_frame_id: "portfolios_table",
          search_url:     portfolios_path,
          new_path:       new_portfolio_path,
          q_object:       @q
        )
      ) do %>

    <%# ===================================================== %>
    <%#                  2a. TABLE ROWS                      %>
    <%# ===================================================== %>

    <% @portfolios.each do |portfolio| %>

      <%# =================================================== %>
      <%#                 2b. PORTFOLIO ROW                  %>
      <%# =================================================== %>

      <%= render(
            Modules::TableRowComponent.new(
              cells: [
                normalize_title(portfolio.name),

                normalize_badge(
                  portfolio.user == current_user ?
                    "Você" :
                    portfolio.user&.full_name
                ),

                portfolio.total_invested_value.present? ?
                  normalize_currency(portfolio.total_invested_value) :
                  normalize_no_data,

                portfolio.total_quotas_held.present? ?
                  normalize_number(portfolio.total_quotas_held) :
                  normalize_no_data
              ],
              model_id:     portfolio.id,
              show_path:    portfolio_path(portfolio),
              edit_path:    edit_portfolio_path(portfolio),
              destroy_path: portfolio_path(portfolio)
            )
          ) %>

    <% end %>

  <% end %>

<% end %>

<%# ========================================================= %>
<%#                      3. FILTERS PANEL                    %>
<%# ========================================================= %>

<%= render(
      Groups::FiltersComponent.new(
        q_object:       @q,
        search_url:     portfolios_path,
        turbo_frame_id: "portfolios_table",
        filters: [
          {
            key:         :name_cont,
            label:       "Nome",
            description: "Mostra carteiras cujo nome contém estes caracteres.",
            placeholder: "Nome da carteira",
            icon_name:   "wallet"
          },
          {
            key:         :user_first_name_cont,
            label:       "Usuário",
            description: "Mostra carteiras pertencentes a usuários cujo nome contém estes caracteres.",
            placeholder: "Nome do responsável",
            icon_name:   "user"
          }
        ]
      )
    ) %>