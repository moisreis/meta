<%#
  VIEW: app/views/portfolios/edit.html.erb
  ACTION: PortfoliosController#edit

  DESCRIPTION:
  Renders the portfolio update page, including the dashboard layout
  wrapper and the shared portfolio form partial configured for
  record updates.

  INSTANCE VARIABLES:
  - @portfolio: [Portfolio] The portfolio record being edited.
  - @form: [ActiveModel] Form object responsible for update
           attributes and validations.
  - @normative_articles: [Enumerable] Collection used to populate
                         normative article selection inputs.
%>

<%# ========================================================= %>
<%#                    1. DASHBOARD WRAPPER                  %>
<%# ========================================================= %>

<%= render(
      Layout::DashboardWrapperComponent.new(
        page_title: "Editar #{@portfolio.name}",
        page_desc: "Atualize as informações da carteira conforme necessário."
      )
    ) do %>

  <%# ======================================================= %>
  <%#                 2. PORTFOLIO FORM PARTIAL              %>
  <%# ======================================================= %>

  <%= render(
        "form",
        portfolio: @form,
        form_url: user_path(@portfolio),
        form_method: :patch,
        button_name: "Atualizar carteira",
        icon_name: "save",
        normative_articles: @normative_articles
      ) %>

<% end %>
