<%#
  PARTIAL: app/views/users/show.html.erb
  DESCRIPTION: Renders the user dashboard with account summary, financial metrics, portfolio table, and recent activity sections.

  LOCAL VARIABLES:
  - @user: [User] Current user instance.
  - @data: [Object] Aggregated dashboard data (metrics, portfolios, activity).
%>

<%= render(Layout::DashboardWrapperComponent.new(
  page_title: @user.full_name,
  page_desc: "Conta de #{@user.email}",
  current_view: "show"
)) do %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Informações da Conta",
      description: "Dados gerais do usuário",
      columns: 4
    )
  ) do %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Nome",
        header_icon: "user",
        badge_text: @user.admin? ? "Administrador" : "Usuário",
        status: @user.admin? ? :teal : :honeysuckle
      )
    ) do %>
      <%= normalize_text(@user.full_name) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Carteiras Próprias",
        header_icon: "wallet",
        status: :default
      )
    ) do %>
      <%= normalize_number(@data.portfolios_count) %>
    <% end %>

  <% end %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Visão Financeira Geral",
      description: "Resumo das principais métricas financeiras",
      columns: 3
    )
  ) do %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Patrimônio Total",
        header_icon: "trending-up",
        status: :teal
      )
    ) do %>
      <%= normalize_currency(@data.total_invested) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Saldo em Conta",
        header_icon: "banknote",
        status: :default
      )
    ) do %>
      <%= normalize_currency(@data.total_balance) %>
    <% end %>

  <% end %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Estatísticas de Atividade",
      description: "Resumo das principais métricas de atividade",
      columns: 4
    )
  ) do %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Total de Acessos",
        header_icon: "log-in",
        status: :default
      )
    ) do %>
      <%= normalize_number(@data.sign_in_count) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Último Acesso",
        header_icon: "globe",
        status: :default
      )
    ) do %>
      <%= normalize_date(@data.last_sign_in_at) %>
    <% end %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Conta Criada",
        header_icon: "user-plus",
        status: :default
      )
    ) do %>
      <%= normalize_date(@data.created_at) %>
    <% end %>

  <% end %>

  <%= render(Groups::TableListComponent.new(
    title: "Carteira",
    collection: @data.portfolios
  )) do |table| %>

    <% table.with_column(label: "Nome da Carteira", icon: "wallet") %>
    <% table.with_column(label: "Fundos", icon: "layers") %>
    <% table.with_column(label: "Valor Total", icon: "coins") %>
    <% table.with_column(label: "Alocação", icon: "shuffle") %>
    <% table.with_column(label: "Criado em", icon: "calendar") %>

    <% @data.portfolios.each do |portfolio| %>
      <% table.with_row(
        model_id: portfolio.id,
        cells: [
          normalize_title(portfolio.name),
          normalize_number(portfolio.fund_investments_count),
          normalize_currency(portfolio.total_invested_value),
          normalize_boolean(portfolio.valid_allocations?, "Válida", "Inválida"),
          normalize_date(portfolio.created_at)
        ],
        show_path: portfolio_path(portfolio),
        edit_path: edit_portfolio_path(portfolio),
        destroy_path: portfolio_path(portfolio)
      ) %>
    <% end %>

  <% end %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Atividade Recente",
      description: "Resumo das últimas atividades do usuário",
      separator: :vertical,
      columns: 2
    )
  ) do %>

    <%= render(Groups::RecentActivityComponent.new(
      title: "Aplicações"
    )) do |component| %>
      <% @data.recent_applications.each do |app| %>
        <%= component.with_item(
          title: app.fund_name,
          value: normalize_currency(app.financial_value),
          sub: app.portfolio_name,
          date: app.request_date,
          color: :success
        ) %>
      <% end %>
    <% end %>

    <%= render(Groups::RecentActivityComponent.new(
      title: "Resgates"
    )) do |component| %>
      <% @data.recent_redemptions.each do |red| %>
        <%= component.with_item(
          title: red.fund_name,
          value: normalize_currency(red.redeemed_liquid_value),
          sub: red.portfolio_name,
          date: red.request_date,
          color: :danger
        ) %>
      <% end %>
    <% end %>

  <% end %>

<% end %>
