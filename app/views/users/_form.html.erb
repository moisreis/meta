<%#
  PARTIAL: app/views/users/_form.html.erb
  DESCRIPTION: Renders user form with fieldsets for email, personal data, and password.

  LOCAL VARIABLES:
  - form: [ActionView::Helpers::FormBuilder] Form builder instance.
  - form_url: [String] Target URL for form submission.
  - form_method: [Symbol] HTTP method for submission (:post or :patch).
%>

<%= form_with(
  model:  @form,
  url:    form_url,
  method: form_method,
  class:  "contents"
) do |form| %>

  <%= render Forms::FieldsetComponent.new(
    title: "E-mail",
    description: "Informe seu endereço de contato principal."
  ) do %>

    <%= render Forms::InputFieldComponent.new(
      f:           form,
      name:        :email,
      label:       "Informe seu e-mail",
      field_type:  :email_field,
      placeholder: "seuemail@email.com",
      desc:        "Informe um e-mail válido",
      icon_name:   "at-sign"
    ) %>

  <% end %>

  <%= render Forms::FieldsetComponent.new(
    title: "Dados do usuário",
    description: "Utilizamos esses nomes para personalizar sua experiência."
  ) do %>

    <%= render Forms::InputFieldComponent.new(
      f:           form,
      name:        :first_name,
      label:       "Primeiro nome",
      field_type:  :text_field,
      placeholder: "Maria",
      desc:        "Informe seu primeiro nome",
      icon_name:   "user-round-pen"
    ) %>

    <%= render Forms::InputFieldComponent.new(
      f:           form,
      name:        :last_name,
      label:       "Último nome",
      field_type:  :text_field,
      placeholder: "Silva",
      desc:        "Informe seu último nome",
      icon_name:   "user-round-pen"
    ) %>

  <% end %>

  <%= render Forms::FieldsetComponent.new(
    title: "Senha",
    description: "Sua senha deve ser mantida em segredo."
  ) do %>

    <%= render Forms::InputFieldComponent.new(
      f:           form,
      name:        :password,
      label:       "Crie uma senha",
      field_type:  :password_field,
      placeholder: "SuaSenha123@",
      desc:        "Crie uma senha segura com, pelo menos, 6 caracteres",
      icon_name:   "key"
    ) %>

    <%= render Forms::InputFieldComponent.new(
      f:           form,
      name:        :password_confirmation,
      label:       "Confirme sua senha",
      field_type:  :password_field,
      placeholder: "SuaSenha123@",
      desc:        "Repita sua senha",
      icon_name:   "key"
    ) %>

  <% end %>

  <%= render Forms::SubmitButtonComponent.new(
    builder: form,
    method:  form_method
  ) %>

<% end %>
