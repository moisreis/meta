<%#
  PARTIAL: app/views/users/new.html.erb
  DESCRIPTION: Renders the user creation page with dashboard wrapper and user form.
%>

<%= render(
  Layout::DashboardWrapperComponent.new(
    page_title: "Criar usuário",
    page_desc: "Gerencie a criação de novos usuários."
  )
) do %>

  <%= render(
    "form",
    form_url:    users_path,
    form_method: :post,
    button_name: "Criar usuário",
    icon_name:   "user-plus"
  ) %>

<% end %>
