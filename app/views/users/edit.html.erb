<%#
  PARTIAL: app/views/users/edit.html.erb
  DESCRIPTION: Renders the user edit page with dashboard wrapper and user form.

  LOCAL VARIABLES:
  - @user: [User] Target user being edited.
%>

<%= render(
  Layout::DashboardWrapperComponent.new(
    page_title: "Editar #{@user.full_name}",
    page_desc: "Atualize suas informações do usuário."
  )
) do %>

  <%= render(
    "form",
    form_url:    user_path(@user),
    form_method: :patch,
    button_name: "Atualizar usuário",
    icon_name:   "save"
  ) %>

<% end %>
