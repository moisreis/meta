<%#
  VIEW: app/views/users/edit.html.erb
  ACTION: UsersController#edit

  DESCRIPTION:
  Renders the user update page, including the dashboard layout
  wrapper and the shared user form partial configured for record updates.

  INSTANCE VARIABLES:
  - @user: [User] The user record being edited.
  - @form: [ActiveModel] Form object responsible for update attributes and validations.
%>

<%# ========================================================= %>
<%#                    1. DASHBOARD WRAPPER                  %>
<%# ========================================================= %>

<%= render(
      Layout::DashboardWrapperComponent.new(
        page_title: "Editar #{@user.full_name}",
        page_desc: "Atualize suas informações do usuário."
      )
    ) do %>

  <%# ======================================================= %>
  <%#                   2. USER FORM PARTIAL                 %>
  <%# ======================================================= %>

  <%= render(
        "form",
        form_url:    user_path(@user),
        form_method: :patch,
        button_name: "Atualizar usuário",
        icon_name:   "save"
      ) %>

<% end %>