<%#
  VIEW: new.html.erb
  ACTION: Devise::PasswordsController#new
  DESCRIPTION: Displays the password reset request form.
               Allows users to submit their email to receive recovery instructions.
  INSTANCE VARIABLES:
    - resource: [User] The Devise resource instance.
    - resource_name: [Symbol] The resource name (:user).
%>
<%= render 'partials/route/auth/wrapper' do %>
  <%= render 'partials/route/auth/container',
             welcome_message: "Perdeu sua senha?",
             welcome_feedback: "Vamos recuperá-la para você!" do
  %>
    <%= form_for(resource,
                 as: resource_name,
                 url: password_path(resource_name),
                 html: { method: :post }) do |f|
    %>
      <%= render "partials/modules/input-field",
                 f: f,
                 name: :email,
                 label: "Informe seu e-mail",
                 field_type: :email_field,
                 placeholder: "seuemail@email.com",
                 desc: "Informe um e-mail válido",
                 icon_name: "at-sign"
      %>
      <%= f.submit "Recuperar minha senha", class: "button" %>
    <% end %>
  <% end %>
<% end %>
