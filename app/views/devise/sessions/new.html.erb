<%#
  VIEW: new.html.erb
  ACTION: Devise::SessionsController#new
  DESCRIPTION: Login form for existing users.
               Collects email and password to establish an authenticated session.
  INSTANCE VARIABLES:
    - resource: [User] The Devise resource instance.
    - resource_name: [Symbol] The resource name (:user).
%>
<%= render 'partials/route/auth/wrapper' do %>
  <%= render 'partials/route/auth/container',
             welcome_message: "Bem-vindo de volta",
             welcome_feedback: "É hora de acompanhar seus resultados, realizar novos aportes e planejar os próximos passos da sua carteira de investimentos" do
  %>
    <%= form_for(resource,
                 as: resource_name,
                 url: session_path(resource_name)) do |f|
    %>
      <%= render "partials/modules/input-field",
                 f: f,
                 name: :email,
                 label: "Informe seu e-mail",
                 field_type: :email_field,
                 placeholder: "seuemail@email.com",
                 desc: "Informe um e-mail válido",
                 icon_name: "at-sign"
      %>
      <%= render "partials/modules/input-field",
                 f: f,
                 name: :password,
                 label: "Informe sua senha",
                 field_type: :password_field,
                 placeholder: "SuaSenha123@",
                 desc: "Informe sua senha de acesso",
                 icon_name: "key"
      %>
      <%= button_tag type: "submit",
                     class: "button" do %>
        <%= inline_svg_tag "icons/arrow-up-right.svg" %>
        <%= content_tag :span, "Entrar" %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
