<%#
  VIEW: app/views/fund_investments/new.html.erb
  ACTION: FundInvestmentsController#new

  DESCRIPTION:
  Renders the fund investment creation page using the dashboard layout
  wrapper and the shared fund investment form partial configured for
  new allocation registration.

  INSTANCE VARIABLES:
  - @fund_investment: [FundInvestment]
    Form-backed fund investment instance used during creation.
%>

<%# ========================================================= %>
<%#                    DASHBOARD WRAPPER                     %>
<%# ========================================================= %>

<%= render(
      Layout::DashboardWrapperComponent.new(
        page_title: "Criar alocação",
        page_desc: "Configure a nova alocação do fundo, definindo como ele será distribuído dentro da carteira."
      )
    ) do %>

  <%# ======================================================= %>
  <%#                 FUND INVESTMENT FORM                   %>
  <%# ======================================================= %>

  <%# --- SHARED FORM PARTIAL ------------------------------ %>

  <%= render(
        "form",
        fund_investment: @fund_investment,
        button_name: AppConstants::CREATE_BUTTON_LABEL,
        icon_name: AppConstants::CREATE_BUTTON_ICON
      ) %>

<% end %>