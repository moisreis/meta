<%#
  PARTIAL: app/views/fund_investments/_form.html.erb

  DESCRIPTION:
  Renders the structured form fields for recording how capital
  is allocated to specific funds, linking investments to
  portfolios and fund records.

  LOCAL VARIABLES:
  - fund_investment: [FundInvestment]
    Form-backed fund investment instance. (required)

  - icon_name: [String]
    Icon identifier rendered inside the submit button. (required)

  - button_name: [String]
    Label text rendered inside the submit button. (required)

  - form_method: [Symbol]
    HTTP method forwarded to the submit button component.
    (default: :post)

  INSTANCE VARIABLES:
  - @investment_funds: [ActiveRecord::Relation]
    Collection of available investment funds.

  - @portfolios: [ActiveRecord::Relation]
    Collection of portfolios available for selection.
%>

<%= form_with(model: fund_investment, class: "contents") do |form| %>

  <%# ===================================================== %>
  <%#                INVESTMENT DESTINATION                 %>
  <%# ===================================================== %>

  <%= render Forms::FieldsetComponent.new(
        title: "Destino do Investimento",
        description: "Selecione o fundo de destino e a carteira onde o ativo será armazenado."
      ) do %>

    <%# --- INVESTMENT FUND SELECT ------------------------ %>

    <%= render Forms::SelectComponent.new(
          f: form,
          name: :investment_fund_id,
          label: "Fundo de investimento",
          options_collection: Shared::InvestmentFundOptionsQuery.call,
          rich: true,
          desc: "Escolha o fundo que está sendo alocado.",
          is_inactive: false
        ) %>

    <%# --- PORTFOLIO SELECT ------------------------------ %>

    <%= render Forms::SelectComponent.new(
          f: form,
          name: :portfolio_id,
          label: "Carteira",
          options_collection: @portfolios.map { |p| [p.name, p.id] },
          desc: "Escolha a carteira que receberá a alocação.",
          is_inactive: false
        ) %>

  <% end %>

  <%# ===================================================== %>
  <%#                    VALUES & QUOTAS                    %>
  <%# ===================================================== %>

  <%= render Forms::FieldsetComponent.new(
        title: "Valores e Cotas",
        description: "Informe os detalhes financeiros e a quantidade de participação no fundo."
      ) do %>

    <%# --- PERCENTAGE ALLOCATION ------------------------- %>

    <%= render Forms::InputFieldComponent.new(
          f: form,
          name: :percentage_allocation,
          label: "Alocação",
          placeholder: "12.5",
          desc: "Percentual da carteira alocado neste fundo.",
          field_type: :number_field,
          icon_name: "badge-percent",
          step: :any
        ) %>

    <%# --- TOTAL QUOTAS HELD ----------------------------- %>

    <%= render Forms::InputFieldComponent.new(
          f: form,
          name: :total_quotas_held,
          label: "Cotas detidas",
          placeholder: "0.000000",
          desc: "Quantidade total de cotas mantidas neste fundo.",
          field_type: :number_field,
          icon_name: "layers",
          step: :any
        ) %>

    <%# --- HIDDEN TOTAL INVESTED VALUE ------------------- %>

    <%= form.hidden_field :total_invested_value, value: 0 %>

  <% end %>

  <%# ===================================================== %>
  <%#                       SUBMISSION                      %>
  <%# ===================================================== %>

  <%= render Forms::SubmitButtonComponent.new(
        builder: form,
        method: local_assigns.fetch(:form_method, :post),
        label: button_name,
        icon: icon_name
      ) %>

<% end %>