<%#
  VIEW: app/views/fund_investments/edit.html.erb
  ACTION: FundInvestmentsController#edit

  DESCRIPTION:
  Renders the fund investment update page using the dashboard
  layout wrapper and the shared fund investment form partial
  configured for record updates.

  INSTANCE VARIABLES:
  - @fund_investment: [FundInvestment]
    The fund investment record being edited.
%>

<%# ======================================================= %>
<%#                    DASHBOARD WRAPPER                    %>
<%# ======================================================= %>

<%= render(
      Layout::DashboardWrapperComponent.new(
        page_title: "Editar alocação ##{@fund_investment.id}",
        page_desc: "Atualize as informações da alocação conforme necessário."
      )
    ) do %>

  <%# ===================================================== %>
  <%#                FUND INVESTMENT FORM                   %>
  <%# ===================================================== %>

  <%# --- SHARED FORM PARTIAL ------------------------------ %>

  <%= render(
        "form",
        fund_investment: @fund_investment,
        form_method: :patch,
        button_name: AppConstants::UPDATE_BUTTON_LABEL,
        icon_name: AppConstants::UPDATE_BUTTON_ICON
      ) %>

<% end %>