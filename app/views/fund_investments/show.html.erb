<%#
  VIEW: app/views/fund_investments/show.html.erb
  ACTION: FundInvestmentsController#show

  DESCRIPTION:
  Displays the complete fund investment dashboard, including
  investment identification data, allocation metrics, position
  summaries, profitability indicators, transaction analytics,
  performance visualizations, and historical operational records.

  INSTANCE VARIABLES:
  - @fund_investment: [FundInvestment]
    Investment allocation being displayed.
  -
    @data: [FundInvestments::ShowService::Result]
    Aggregated investment analytics, charts, financial summaries,
    and historical transaction data.
%>

<%# ======================================================= %>
<%#                    DASHBOARD WRAPPER                    %>
<%# ======================================================= %>

<%= render(Layout::DashboardWrapperComponent.new(
  page_title: @fund_investment.investment_fund.fund_name,
  page_desc: "Investimento na carteira #{@fund_investment.portfolio.name}",
  current_view: "show"
)) do %>

  <%# ===================================================== %>
  <%#                  INVESTMENT OVERVIEW                  %>
  <%# ===================================================== %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Visão Geral do Investimento",
      description: "Dados principais e identificação",
      columns: 4
    )
  ) do %>

    <%# --- PORTFOLIO -------------------------------------- %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Carteira",
        header_icon: "briefcase",
        badge_text: normalize_text(
          @fund_investment.portfolio.user.full_name
        ),
      )
    ) do %>
      <%= normalize_text(@fund_investment.portfolio.name) %>
    <% end %>

    <%# --- INVESTMENT FUND ------------------------------- %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Fundo de Investimento",
        header_icon: "building-2",
        badge_text: normalize_text(
          @fund_investment.investment_fund.cnpj
        ),
      )
    ) do %>
      <%= normalize_text(
        @fund_investment.investment_fund.fund_name
      ) %>
    <% end %>

    <%# --- PORTFOLIO ALLOCATION -------------------------- %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Alocação na Carteira",
        header_icon: "chart-pie",
      )
    ) do %>
      <%= normalize_percentage(
        @fund_investment.percentage_allocation
      ) %>
    <% end %>

  <% end %>

  <%# ===================================================== %>
  <%#                    POSITION METRICS                   %>
  <%# ===================================================== %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Métricas de Posição",
      description: "Valores atuais e saldos",
      columns: 4
    )
  ) do %>

    <%# --- TOTAL INVESTED VALUE -------------------------- %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Valor Total Investido",
        header_icon: "banknote",
        status: :secondary
      )
    ) do %>
      <%= normalize_currency(
        @fund_investment.total_invested_value
      ) %>
    <% end %>

    <%# --- HELD QUOTAS ----------------------------------- %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Cotas Detidas",
        header_icon: "scale"
      )
    ) do %>
      <%= normalize_number(
        @fund_investment.total_quotas_held
      ) %>
    <% end %>

    <%# --- CURRENT MARKET VALUE -------------------------- %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Valor de Mercado Atual",
      )
    ) do %>
      <%= normalize_currency(
        @data.current_market_value
      ) %>
    <% end %>

    <%# --- UNREALIZED RESULT ----------------------------- %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Ganhos e Perdas",
      )
    ) do %>
      <%= normalize_currency(
        @data.unrealized_gain_loss
      ) %>
    <% end %>

  <% end %>

  <%# ===================================================== %>
  <%#                  PERFORMANCE METRICS                  %>
  <%# ===================================================== %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Performance e Retorno",
      description: "Análise de rentabilidade do investimento",
      columns: 4
    )
  ) do %>

    <%# --- TOTAL APPLICATIONS ---------------------------- %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Total de Aplicações",
        header_icon: "arrow-up-right",
        status: :success
      )
    ) do %>
      <%= normalize_currency(
        @data.total_applications
      ) %>
    <% end %>

    <%# --- TOTAL REDEMPTIONS ----------------------------- %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Total de Resgates",
        header_icon: "arrow-down-left",
        status: :honeysuckle
      )
    ) do %>
      <%= normalize_currency(
        @data.total_redemptions
      ) %>
    <% end %>

    <%# --- NET CASH FLOW --------------------------------- %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Fluxo Líquido",
        header_icon: "repeat",
        status: :teal
      )
    ) do %>
      <%= normalize_currency(
        @data.total_gain
      ) %>
    <% end %>

    <%# --- RETURN ON INVESTMENT -------------------------- %>

    <%= render(
      Blocks::CardComponent.new(
        title: "Retorno sobre Investimento",
        header_icon: "trending-up",
        status: @data.return_percentage >= 0 ?
                  :success :
                  :danger
      )
    ) do %>
      <%= normalize_percentage(
        @data.return_percentage
      ) %>
    <% end %>

  <% end %>

  <%# ===================================================== %>
  <%#               PERFORMANCE VISUALIZATION               %>
  <%# ===================================================== %>

  <%= render(
    Blocks::SectionComponent.new(
      title: "Visualizações de Performance",
      columns: 2
    )
  ) do %>

    <%# --- TRANSACTION DISTRIBUTION ---------------------- %>

    <%= render Groups::ChartListComponent.new(
      chart_type: :pie_chart,
      chart_title: "Distribuição de Transações",
      data_source: @data.transaction_distribution_chart,
      chart_options: Charts::PieChartOptionsBuilder.call(
        @data.transaction_distribution_chart
      )
    ) %>

    <%# --- MONTHLY CASH FLOW ----------------------------- %>

    <%= render Groups::ChartListComponent.new(
      chart_type: :line_chart,
      chart_title: "Fluxo Mensal de Transações",
      data_source: @data.monthly_transaction_flows_chart,
      chart_options: Charts::LineSeriesChartOptionsBuilder.call(
        @data.monthly_transaction_flows_chart
      )
    ) %>

  <% end %>

  <%# ===================================================== %>
  <%#                  APPLICATION HISTORY                  %>
  <%# ===================================================== %>

  <%= render(Groups::TableListComponent.new(
    title: "Histórico de Aplicações",
    collection: @data.applications,
  )) do |table| %>

    <%# --- TABLE COLUMNS --------------------------------- %>

    <% table.with_column(
      label: "Solicitação",
      icon: "calendar-plus"
    ) %>

    <% table.with_column(
      label: "Valor Financeiro",
      icon: "banknote"
    ) %>

    <% table.with_column(
      label: "Cotas Adquiridas",
      icon: "percent"
    ) %>

    <% table.with_column(
      label: "Cotação na Aplicação",
      icon: "calculator"
    ) %>

    <% table.with_column(
      label: "Cotização",
      icon: "calendar-setting"
    ) %>

    <% table.with_column(
      label: "Liquidação",
      icon: "calendar-check-2"
    ) %>

    <%# --- TABLE ROWS ------------------------------------ %>

    <% @data.applications.each do |app| %>

      <% table.with_row(
        model_id: app.id,
        show_path:    application_path(app),
        edit_path:    edit_application_path(app),
        destroy_path: application_path(app),
        cells: [
          normalize_date(app.request_date),
          normalize_currency(app.financial_value),
          normalize_number(app.number_of_quotas),
          normalize_currency(app.quota_value_at_application),
          normalize_date(app.cotization_date),
          normalize_date(app.liquidation_date)
        ]
      ) %>

    <% end %>

  <% end %>

  <%# ===================================================== %>
  <%#                   REDEMPTION HISTORY                  %>
  <%# ===================================================== %>

  <%= render(Groups::TableListComponent.new(
    title: "Histórico de Resgates",
    
    collection: @data.redemptions,
  )) do |table| %>

    <%# --- TABLE COLUMNS --------------------------------- %>

    <% table.with_column(
      label: "Solicitação",
      icon: "calendar-plus"
    ) %>

    <% table.with_column(
      label: "Cotas Resgatadas",
      icon: "arrow-down-to-line"
    ) %>

    <% table.with_column(
      label: "Valor Líquido",
      icon: "coins"
    ) %>

    <% table.with_column(
      label: "Tipo de Resgate",
      icon: "tag"
    ) %>

    <% table.with_column(
      label: "Rendimento",
      icon: "trending-up-down"
    ) %>

    <% table.with_column(
      label: "Cotização",
      icon: "calculator"
    ) %>

    <% table.with_column(
      label: "Liquidação",
      icon: "calendar-check-2"
    ) %>

    <%# --- TABLE ROWS ------------------------------------ %>

    <% @data.redemptions.each do |red| %>

      <% table.with_row(
        model_id: red.id,
        show_path:    redemption_path(red),
        destroy_path: redemption_path(red),
        cells: [
          normalize_date(red.request_date),
          normalize_number(red.redeemed_quotas),
          normalize_currency(red.redeemed_liquid_value),
          normalize_badge(
            FundInvestments::RedemptionTypeLabels.call(
              red.redemption_type
            )
          ),
          normalize_trend(red.redemption_yield),
          normalize_date(red.cotization_date),
          normalize_date(red.liquidation_date)
        ]
      ) %>

    <% end %>

  <% end %>

  <%# ===================================================== %>
  <%#                  PERFORMANCE HISTORY                  %>
  <%# ===================================================== %>

  <%= render(Groups::TableListComponent.new(
    title: "Histórico de Performance",
    collection: @data.performance_histories,
  )) do |table| %>

    <%# --- TABLE COLUMNS --------------------------------- %>

    <% table.with_column(
      label: "Data do Registro",
      icon: "calendar"
    ) %>

    <% table.with_column(
      label: "Valor de Mercado",
      icon: "trending-up"
    ) %>

    <% table.with_column(
      label: "Valor Investido",
      icon: "banknote"
    ) %>

    <% table.with_column(
      label: "Ganho/Perda",
      icon: "trending-up-down"
    ) %>

    <%# --- TABLE ROWS ------------------------------------ %>

    <% @data.performance_histories.each do |perf| %>

      <% table.with_row(
        model_id: perf.id,
        cells: [
          normalize_date(perf.created_at),
          normalize_currency(perf.market_value),
          normalize_currency(perf.invested_value),
          normalize_currency(
            perf.market_value - perf.invested_value
          ),
        ]
      ) %>

    <% end %>

  <% end %>

<% end %>