<%#
  VIEW: app/views/fund_investments/index.html.erb
  ACTION: FundInvestmentsController#index

  DESCRIPTION:
  Displays the fund investment listing page with searchable,
  filterable, sortable, and paginated records using reusable
  dashboard and table components.

  INSTANCE VARIABLES:
  - @fund_investments: [ActiveRecord::Relation<FundInvestment>]
    Paginated fund investment collection.

  - @q: [Ransack::Search]
    Search object used for filtering and sorting.

  - @total_items: [Integer]
    Total filtered fund investment count.
%>

<%# ======================================================= %>
<%#                    DASHBOARD WRAPPER                    %>
<%# ======================================================= %>

<%= render(
      Layout::DashboardWrapperComponent.new(
        page_title: "Lista de Alocações",
        page_desc: "Acompanhe como os fundos estão distribuídos entre as carteiras.",
        current_view: "datatable"
      )
    ) do %>

  <%# ===================================================== %>
  <%#               FUND INVESTMENTS DATA TABLE             %>
  <%# ===================================================== %>

  <%= render(
        Groups::DataTableComponent.new(
          columns: [
            { label: "Fundo",           icon: "layers" },
            { label: "Carteira",        icon: "wallet" },
            { label: "Alocação",        icon: "shuffle" },
            { label: "Valor investido", icon: "banknote" },
            { label: "Cotas totais",    icon: "percent" },
            { label: "Criado em",       icon: "calendar" },
          ],
          rows: @fund_investments,
          turbo_frame_id: "fund_investments_table",
          search_url: fund_investments_path,
          new_path: new_fund_investment_path,
          q_object: @q,
        )
      ) do %>

    <%# --- TABLE ROWS ------------------------------------ %>

    <% @fund_investments.each do |fund_investment| %>

      <%# --- FUND INVESTMENT ROW ------------------------- %>

      <%= render(
            Modules::TableRowComponent.new(
              cells: [

                normalize_title(
                  fund_investment.investment_fund&.fund_name
                ),

                normalize_badge(
                  fund_investment.portfolio&.name
                ),

                normalize_percentage(
                  fund_investment.percentage_allocation
                ),

                fund_investment.total_invested_value.present? ?
                  normalize_currency(
                    fund_investment.total_invested_value
                  ) :
                  normalize_no_data,

                fund_investment.total_quotas_held.present? ?
                  normalize_number(
                    fund_investment.total_quotas_held
                  ) :
                  normalize_no_data,

                normalize_date(
                  fund_investment.created_at
                ),

              ],
              model_id: fund_investment.id,
              show_path: fund_investment_path(fund_investment),
              edit_path: edit_fund_investment_path(fund_investment),
              destroy_path: fund_investment_path(fund_investment)
            )
          ) %>

    <% end %>

  <% end %>

<% end %>

<%# ======================================================= %>
<%#                      FILTERS PANEL                      %>
<%# ======================================================= %>

<%= render(
      Groups::FiltersComponent.new(
        q_object: @q,
        search_url: fund_investments_path,
        turbo_frame_id: "fund_investments_table",
        filters: [
          {
            key: :portfolio_name_cont,
            label: "Carteira",
            description: "Exibe alocações vinculadas a carteiras cujo nome corresponda.",
            placeholder: "Nome da carteira",
            icon_name: "wallet"
          },
          {
            key: :investment_fund_fund_name_cont,
            label: "Fundo",
            description: "Filtra alocações pelo fundo investido.",
            placeholder: "Nome do fundo",
            icon_name: "chart-pie"
          },
          {
            key: :percentage_allocation_gteq,
            label: "Alocação",
            description: "Exibe alocações com percentual igual ou superior ao informado.",
            placeholder: "Percentual mínimo",
            icon_name: "badge-percent"
          },
          {
            key: :total_invested_value_gteq,
            label: "Valor investido",
            description: "Filtra alocações com valor investido acima do indicado.",
            placeholder: "Valor mínimo",
            icon_name: "banknote"
          }
        ]
      )
    ) %>