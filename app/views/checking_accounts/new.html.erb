<%#
  VIEW: new.html.erb
  ACTION: CheckingAccountsController#new
  DESCRIPTION: Renders the page for creating a new CheckingAccount.
               Uses the shared form partial inside the dashboard wrapper.
  INSTANCE VARIABLES:
    - @checking_account: [CheckingAccount] A new (unsaved) CheckingAccount instance.
    - @portfolio: [Portfolio] The parent portfolio for nested routing.
%>
<%= render 'partials/route/dashboard/wrapper',
           page_title: "Nova Conta Corrente",
           page_desc: "Adicione uma disponibilidade em conta corrente para #{@portfolio.name}." do
%>

  <%= render "form",
             checking_account: @checking_account,
             portfolio: @portfolio,
             button_name: "Adicionar",
             icon_name: "plus"
  %>
<% end %>
