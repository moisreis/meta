<%#
  VIEW: edit.html.erb
  ACTION: CheckingAccountsController#edit
  DESCRIPTION: Renders the page for updating an existing CheckingAccount.
               Displays the form inside the dashboard wrapper with a danger zone for deletion.
  INSTANCE VARIABLES:
    - @checking_account: [CheckingAccount] The account being edited.
    - @portfolio: [Portfolio] The parent portfolio for nested routing.
%>
<%= render 'partials/route/dashboard/wrapper',
           page_title: "Editar #{@checking_account.name}",
           page_desc: "Atualize as informações da conta corrente conforme necessário." do
%>

  <%= render "form",
             checking_account: @checking_account,
             portfolio: @portfolio,
             button_name: "Atualizar",
             icon_name: "refresh-cw"
  %>
<% end %>
