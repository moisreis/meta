<%#
  VIEW: show.html.erb
  ACTION: CheckingAccountsController#show
  DESCRIPTION: Displays detailed information for a single CheckingAccount.
               Shows balance KPIs, identification data, and notes.
  INSTANCE VARIABLES:
    - @checking_account: [CheckingAccount] The account record being displayed.
    - @portfolio: [Portfolio] The parent portfolio.
%>

<%= render 'partials/route/dashboard/wrapper',
           page_title: @checking_account.name,
           page_desc: "#{@checking_account.institution_label} — #{l(@checking_account.reference_date, format: :month_year)}",
           current_view: "show" do
%>

  <%# ====== SUMMARY KPIS ====== %>
  <%= render "partials/route/dashboard/section",
             section_title: "Resumo",
             columns: 3 do
  %>

    <%= render(
          "partials/route/dashboard/card",
          card_title: "Saldo da Conta",
          card_icon: "banknote",
          card_data: normalize_card_text(@checking_account.institution_label),
          status: "success"
        ) do
    %>
      <%= normalize_currency(@checking_account.balance) %>
    <% end %>

    <%= render(
          "partials/route/dashboard/card",
          card_title: "Mês de Referência",
          card_icon: "calendar"
        ) do
    %>
      <%= normalize_date(@checking_account.reference_date) %>
    <% end %>

    <%= render(
          "partials/route/dashboard/card",
          card_title: "Moeda",
          card_icon: "circle-dollar-sign"
        ) do
    %>
      <%= normalize_title(@checking_account.currency) %>
    <% end %>
  <% end %>

  <%# ====== IDENTIFICATION ====== %>
  <%= render "partials/route/dashboard/section",
             section_title: "Identificação",
             columns: 2 do
  %>

    <%= render(
          "partials/route/dashboard/card",
          card_title: "Nome / Descrição",
          card_icon: "tag"
        ) do
    %>
      <%= normalize_title(@checking_account.name) %>
    <% end %>

    <%= render(
          "partials/route/dashboard/card",
          card_title: "Instituição Financeira",
          card_icon: "landmark"
        ) do
    %>
      <%= normalize_title(@checking_account.institution_label) %>
    <% end %>

    <%= render(
          "partials/route/dashboard/card",
          card_title: "Número da Conta",
          card_icon: "hash"
        ) do
    %>
      <%= normalize_title(@checking_account.account_number.presence) || normalize_title("Não informado") %>
    <% end %>

    <%= render(
          "partials/route/dashboard/card",
          card_title: "Carteira Vinculada",
          card_icon: "wallet"
        ) do
    %>
    <%= normalize_title(@portfolio.name) %>
    <% end %>
  <% end %>

  <%# ====== NOTES ====== %>
  <% if @checking_account.notes.present? %>
    <%= render "partials/route/dashboard/section",
               section_title: "Observações",
               columns: 1 do
    %>
      <p class="text-sm text-muted"><%= @checking_account.notes %></p>
    <% end %>
  <% end %>
<% end %>
