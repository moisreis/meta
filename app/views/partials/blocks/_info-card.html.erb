<% main_color ||= "primary" %>
<% c = INFO_CARD_COLORS.fetch(main_color, INFO_CARD_COLORS["primary"]) %>

<div class="grid grid-cols-2 items-center gap-4 px-4 py-3.5 bg-white border border-border rounded-base">

  <%# Left — icon + title/subtitle %>
  <div class="flex items-center gap-3 min-w-0">

    <div class="size-7 rounded-full flex-shrink-0 flex items-center justify-center <%= c[:bg] %>">
      <%= inline_svg_tag "icons/#{icon_name}.svg", class: "#{c[:stroke]} !size-3.5" %>
    </div>

    <div class="flex flex-col gap-0.5 min-w-0">
      <%= content_tag :span, title,
            class: "text-sm font-medium text-body truncate" %>
      <%= content_tag :span, subtitle,
            class: "font-mono text-muted uppercase text-3xs tracking-wide" %>
    </div>

  </div>

  <%# Right — main value + sub value %>
  <div class="flex flex-col items-end gap-0.5">
    <%= content_tag :span, main_value,
          class: "font-heading text-xl font-normal tracking-tight #{c[:text]}" %>
    <%= content_tag :span, sub_value,
          class: "font-mono text-muted uppercase text-3xs tracking-wide" %>
  </div>

</div>
