<%#
  Partial : _chart.html.erb
  Date    : 2025-11-30
  Author  : Moisés Reis
  Package : Meta
%>

<% chart_id    ||= nil %>
<% chart_meta  ||= nil %>  <%# ex: "2026", "Últ. 3 meses" — texto secundário no header %>

<div class="bg-white border border-border rounded-base flex flex-col overflow-hidden"
     data-chart-id="<%= chart_id %>">

  <%# Header %>
  <div class="flex items-center justify-between px-6 py-3 flex-shrink-0">
    <div class="flex items-center gap-3">
      <span class="size-[5px] rounded-full bg-neutral-300 flex-shrink-0"></span>
      <%= content_tag :h3, chart_title, class: "font-mono text-muted uppercase text-xs tracking-widest font-medium" %>
    </div>
    <% if chart_meta.present? %>
      <span class="font-mono text-muted uppercase text-3xs tracking-wide"><%= chart_meta %></span>
    <% end %>
  </div>

  <%# Body %>
  <div class="flex items-center justify-center h-full p-5">
    <% if data_source.any? %>
      <%= yield %>
    <% else %>
      <p class="font-mono text-muted uppercase text-3xs tracking-widest py-16">
        Nenhum dado disponível
      </p>
    <% end %>
  </div>

</div>
