<%#
  Partial : _chart.html.erb
  Date    : 11/30/2025
  Author  : Moisés Reis
  Package : Meta

  Description:
    Reusable frame for rendering data charts consistently across the dashboard.
    Wraps any chart implementation in a titled header and a white content area,
    and renders an empty state badge when the data source has no records.

  ============================================================
  Locals
  ============================================================

  @param  chart_title  [String]   Label displayed in the card header. Required.
  @param  chart_id     [String]   Value written to data-chart-id on the root element. Optional.
  @param  data_source  [Array]    Collection checked for presence before yielding. Required.

  ============================================================
  Notes
  ============================================================

  - chart_title and data_source are expected to be passed but have no ||= default.
    Callers must provide both or the template will raise a NameError.

  @yield  [content]  The chart markup rendered inside the white content area
                     when data_source is non-empty.
%>

<% chart_id ||= nil %>

<div class="bg-neutral-50 border border-border rounded-base flex flex-col" data-chart-id="<%= chart_id %>">

  <%# =============================================================
      Chart Header — Title
      ============================================================= %>
  <div class="w-full flex flex-row justify-between items-center h-9 px-3 py-1.5 bg-input border-b border-border">
    <%= content_tag :h3, chart_title, class: "font-mono text-body capitalize font-normal text-sm" %>
  </div>

  <%# =============================================================
      Chart Body — Content or Empty State
      ============================================================= %>
  <div class="p-6 flex items-center justify-center bg-white rounded-base h-full">

    <%# Note: Renders the empty state badge instead of yielding when data_source
              has no records, preventing charting libraries from receiving an empty
              dataset and potentially throwing a JavaScript error. %>
    <% if data_source.any? %>
      <%= yield %>
    <% else %>
      <%= content_tag :p, "Sem dados", class: "badge badge-accent" %>
    <% end %>

  </div>

</div>