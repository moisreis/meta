<%#
  Partial : _sidebar.html.erb
  Date    : 11/20/2025
  Author  : Moisés Reis
  Package : Meta

  Description:
    Primary navigation sidebar rendered on every dashboard page.
    Displays the app logo, global actions, and a full set of CRUD navigation
    groups for every managed resource in the application.

  ============================================================
  Dependencies
  ============================================================

  @uses   current_user   Implicit dependency via crud_nav_for and authenticated_root_path.

  ============================================================
  Notes
  ============================================================

  - This partial accepts no locals. It is always rendered in full.
  - crud_nav_for is a helper that generates an index link and a new-record
    link for the given model. Consult ApplicationHelper for its full signature.
  - The aside uses arbitrary Tailwind variants ([&>div]:...) to apply layout
    rules uniformly to all direct children without adding wrapper classes to each.
%>

<aside class="flex flex-col justify-start items-center h-screen col-span-6 md:col-span-4 xl:col-span-2 max-h-screen sticky no-scrollbar overflow-y-auto top-0 [&>div]:px-0 [&>div]:flex [&>div]:flex-col [&>div]:items-start [&>div]:justify-center [&>div]:gap-1.5 bg-primary-950 border-r border-border px-3 py-3">

  <%# =============================================================
      Logo
      ============================================================= %>
  <div class="h-16 bg-transparent items-center justify-start w-full !px-3 3xl:!px-6">
    <%= render "partials/blocks/composed-avatar" %>
  </div>

  <div class="flex flex-col h-full !justify-between [&>div]:flex [&>div]: [&>div]:flex-col [&>div]:!gap-9 [&>div]:!py-6 [&>div]:items-center [&>div]:justify-center [&>div]:w-full [&>div>div]:w-full [&>div>div]:space-y-1.5">
    <div>

      <%# =============================================================
          Global Actions — Home & Sign Out
          ============================================================= %>
      <div>
        <%= link_to authenticated_root_path,
                    class: "button button-sidebar w-full button-small flex justify-start" do %>
          <%= inline_svg_tag "icons/home.svg" %>
          <%= content_tag :span, "Início" %>
        <% end %>

        <%# Note: Sends a DELETE request with a confirmation dialog before
                  destroying the session. The form style override is required
                  to keep the button aligned inside the flex sidebar column. %>
        <%= button_to destroy_user_session_path,
                      method: :delete,
                      data: { turbo_confirm: "Tem certeza que deseja sair?" },
                      class: "button button-sidebar w-full button-small flex justify-start",
                      form: { style: "display: flex; align-items: center;" } do %>
          <%= inline_svg_tag "icons/log-out.svg" %>
          <%= content_tag :span, "Sair" %>
        <% end %>
      </div>

      <%# =============================================================
          Resource Navigation — crud_nav_for Groups
          ============================================================= %>

      <%# Note: Each crud_nav_for call generates an index and a new-record
                button for that model. Add or remove entries here as
                resources are introduced or retired from the application. %>
      <%= crud_nav_for Portfolio,
                       singular: "Carteira",
                       plural: "Carteiras",
                       icons: { index: "wallet.svg", new: "plus.svg" } %>

      <%= crud_nav_for User,
                       singular: "Usuário",
                       plural: "Usuários",
                       icons: { index: "users.svg", new: "plus.svg" } %>

      <%= crud_nav_for InvestmentFund,
                       singular: "Credenciamento",
                       plural: "Credenciamentos",
                       icons: { index: "chart-pie.svg", new: "plus.svg" } %>

      <%= crud_nav_for Application,
                       singular: "Aplicação",
                       plural: "Aplicações",
                       icons: { index: "arrow-left-right.svg", new: "plus.svg" } %>

      <%= crud_nav_for Redemption,
                       singular: "Resgate",
                       plural: "Resgates",
                       icons: { index: "circle-minus.svg", new: "plus.svg" } %>

      <%= crud_nav_for NormativeArticle,
                       singular: "Norma",
                       plural: "Normas",
                       icons: { index: "scale.svg", new: "plus.svg" } %>

      <%= crud_nav_for FundValuation,
                       singular: "CVM",
                       plural: "CVM",
                       icons: { index: "calendar-setting.svg", new: "plus.svg" } %>

      <%= crud_nav_for EconomicIndex,
                       singular: "Índice",
                       plural: "Índices",
                       icons: { index: "trending-up.svg", new: "plus.svg" } %>

      <%= crud_nav_for EconomicIndexHistory,
                       singular: "Histórico",
                       plural: "Históricos",
                       icons: { index: "calendar-clock.svg", new: "plus.svg" } %>

    </div>
  </div>

</aside>