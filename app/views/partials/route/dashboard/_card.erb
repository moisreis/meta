<%#
  # Partial: _card.html.erb
  # Date: 2025-11-14
  # Author: Moisés Reis
  # Package: Meta
  #
  # Description: Renders a single-metric display card designed for dashboard environments.
  #              It features a labeled header with an icon, a large primary value area,
  #              and an optional badge for displaying trends, dates, or secondary data.
  #
  # Locals:
  # @param [Symbol] status - The color theme key (e.g., :success, :danger). Defaults to :default.
  # @param [Boolean] is_outline - Toggles the badge to an outlined visual style. Defaults to true.
  # @param [String] card_title - The label text shown in the header of the card.
  # @param [String] card_icon - The filename for the SVG icon displayed next to the title.
  # @param [String] card_data - Supplementary text rendered inside a status badge.
  # @param [String] card_data_icon - An optional icon filename to prepend to the badge text.
  #
  # Usage: - What: Renders a standardized visual container for key performance indicators (KPIs).
  #        - How: This partial is called within dashboard sections, receiving metric data and
  #               optional status symbols to determine its color palette.
  #        - Why: Provides a consistent, scannable interface for monitoring various financial
  #               metrics at a glance without cluttering the main view.
  #
  # @yield [content] The primary metric or value to be displayed prominently in the card body.
  %>

  <% status ||= :default %>
  <% card_title ||= nil %>
  <% card_icon ||= nil %>
  <% card_data ||= nil %>
  <% card_data_icon ||= nil %>

  <% dot_color = {
    success:     "bg-success-500",
    danger:      "bg-danger-500",
    alert:       "bg-alert-500",
    primary:     "bg-primary-500",
    teal:        "bg-teal-500",
    honeysuckle: "bg-honeysuckle-500",
    indigo:      "bg-indigo-500",
    secondary:   "bg-secondary-500",
    default:     "bg-neutral-300"
  }[status.to_sym] || "bg-neutral-300" %>

  <div class="rounded-base border border-border bg-white flex flex-col gap-5 px-5 pt-5 pb-4">

    <%# Header %>
    <div class="flex items-center gap-3">
      <span class="relative -top-[1px] size-[5px] rounded-full flex-shrink-0 <%= dot_color %>"></span>
      <%= content_tag :p, card_title, class: "font-mono text-muted uppercase text-xs tracking-widest font-medium" %>
    </div>

    <%# Primary value %>
    <div class="[&>div>span]:!font-heading [&>div>svg]:!w-6 [&>div>svg]:!h-6 [&>span]:!font-heading [&>div>span]:!text-4xl [&>span]:!text-4xl [&>div>span]:font-bold [&>div>span]:font-bold [&>div>span]:tracking-tight [&>div>span]:text-heading line-clamp-1">
      <%= yield %>
    </div>

    <%# Divider + footer %>
    <div class="border-t border-border pt-3">
      <% if card_data.present? %>
        <div class="badge badge-accent">
          <% if card_data_icon.present? %>
            <span class="[&>svg]:size-3 [&>svg]:stroke-muted">
              <%= inline_svg_tag "icons/#{card_data_icon}.svg" %>
            </span>
          <% end %>
          <p class="font-mono text-muted uppercase text-3xs tracking-wide"><%= card_data %></p>
        </div>
      <% else %>
        <div class="h-3.5"></div>
      <% end %>
    </div>

  </div>
