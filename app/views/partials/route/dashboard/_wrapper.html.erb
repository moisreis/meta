<%#
  # Partial: _wrapper.html
  # Date: 11/13/2025
  # Author: Moisés Reis
  # Package: Meta
  #
  # Description: This file creates the main structural frame for the dashboard.
  #              It organizes how the sidebar and the main content area fit
  #              together on the screen using a grid system.
  #
  # Usage: - What: This partial acts as a master container that wraps around
  #                different views like forms or tables to keep them organized.
  #        - How: It sets up a large grid layout, places the navigation sidebar
  #               on one side, and leaves a dedicated space for the main content.
  #        - Why: It ensures that every page in the dashboard looks consistent
  #               and follows the same layout rules without repeating code.
  %>

<%# Explanation:: This line checks if a specific view type is already set.
  #               If no type is provided, it safely defaults to a form
  #               layout to ensure the page displays correctly.
  %>
<% current_view ||= "form" %>

<%# Explanation:: This block sets the text that appears on the browser tab.
  #               It combines the app name with a specific page title
  #               to help the user identify which section they are visiting.
  %>
<% content_for :title do %>
  Meta - <%= page_title %>
<% end %>

<main class="grid grid-cols-16 justify-start w-screen no-scrollbar"
      data-controller="sidebar">

  <%= render 'partials/route/dashboard/sidebar' %>

  <%# Add data-sidebar-target here so the controller can resize it %>
  <div data-sidebar-target="container"
       class="col-span-10 md:col-span-12 xl:col-span-14">
    <%= render 'partials/route/dashboard/container',
               page_title: page_title,
               page_desc: page_desc,
               current_view: current_view do %>
      <%= yield %>
    <% end %>
  </div>

</main>