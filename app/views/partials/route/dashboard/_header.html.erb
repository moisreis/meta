<%#
# Partial Name: portfolio_header.erb
# Date: 2026-03-10
# Author: Moisés Reis
# Package: Portfolios
#
# Description:: This partial represents the persistent top navigation bar used
#               within the portfolio management interface. It provides tools
#               for switching between portfolios, triggering performance
#               calculations, and exporting data reports to PDF files.
#
# Locals:: @param [Portfolio] portfolio - The current portfolio instance being viewed.
#          @param [Date] reference_date - The date used to pre-fill calculation forms.
#
# Notes:: The sticky behavior and background blur are handled by CSS classes to
#         ensure the bar remains accessible while scrolling through data.
%>

<%# ============================================================= %>
<%# Portfolio Selection & Quick View %>
<%# ============================================================= %>

<%# This container groups the portfolio dropdown and the direct link
    to view details. It allows the user to quickly navigate between
    different investment sets managed within their account. %>
<div class="h-14 px-16 flex flex-row justify-between items-center gap-6 bg-white border-b border-border">

  <div class="flex flex-row items-center gap-3">

      <button data-action="click->sidebar#toggle"
              class="button button-outline !w-7 button-small flex-shrink-0"
              title="Menu">
      <span class="icon-sidebar-open">
        <%= inline_svg_tag "icons/panel-left-close.svg" %>
      </span>
        <span class="icon-sidebar-close">
          <%= inline_svg_tag "icons/panel-left-open.svg" %>
        </span>
      </button>


      <div class="h-7 w-[1px] bg-border"></div>
    <%= form_with url: "#",
                  method: :get,
                  id: "portfolio-selector-form",
                  class: "flex flex-row items-center justify-start gap-2",
                  html: { role: "presentation" } do |f| %>
      <div class="relative flex flex-col justify-start gap-1.5">
        <div class="relative [&>div>div]:!w-[320px]">

          <%# This partial renders the searchable select input.
              It lists all portfolios owned by the current user
              to enable rapid context switching. %>
          <%= render "partials/modules/select",
                     f: f,
                     name: :portfolio_id,
                     selected: @portfolio&.id,
                     options_collection: current_user.portfolios.map { |p| [p.name, p.id] },
                     desc: nil,
                     is_half_width: false,
                     is_small: true,
                     is_inactive: false %>
        </div>
      </div>

      <%# This link navigates the user to the specific portfolio page.
          Its destination is updated dynamically by JavaScript when
          the dropdown value changes. %>
      <%= link_to portfolio_path(current_user.portfolios.first&.id || 0),
                  id: "view-portfolio-link",
                  class: "button button-outline button-small",
                  data: {
                    turbo_frame: "_top",
                    base_url: "/portfolios/"
                  } do %>
        <%= inline_svg_tag "icons/arrow-up-right.svg" %>
        <%= content_tag :span, "Ver carteira" %>
      <% end %>
    <% end %>
  </div>

  <div class="flex flex-row items-center justify-end gap-3">
  <% if controller_name == "fund_valuations" && action_name == "index" %>
    <div class="flex flex-row items-center">
      <%= form_with url: trigger_import_fund_valuations_path,
                    method: :post,
                    data: {
                      controller: "calculation-progress",
                      action: "submit->calculation-progress#submit",
                      "calculation-progress-poll-url-value": import_progress_fund_valuations_path
                    } do |f| %>
        <%= f.button type: "submit", class: "button button-primary button-small" do %>
          <%= content_tag :span, "Importar Cotações" %>
        <% end %>
      <% end %>
    </div>
    <div class="h-7 w-[1px] bg-border"></div>

  <% end %>

  <% if controller_name == "portfolios" && action_name == "show" %>
    <div class="flex flex-row justify-start gap-3 items-center"
         data-controller="reference-date">

      <%# Provides a visual date picker input that serves as the primary
          trigger for updating the dashboard reference timeframe. %>
      <%= form_with url: "#",
                    method: :get,
                    local: true,
                    id: "reference-date-dummy-form",
                    class: "w-fit" do |f|
      %>
        <div data-reference-date-target="inputWrapper">
          <%= render "partials/modules/date-field",
                     f: f,
                     name: :reference_date,
                     label: nil,
                     desc: nil,
                     is_small: true,
                     is_half_width: false,
                     icon_name: "calendar",
                     value: @reference_date
          %>
        </div>
      <% end %>

      <%# Handles the GET request to refresh the dashboard view based
          on the selected reference date provided by the user. %>
      <%= form_with url: portfolio_path(@portfolio),
                    method: :get,
                    local: true,
                    id: "form-view-period",
                    data: { reference_date_target: "viewForm" },
                    class: "hidden" do |f|
      %>
        <%= hidden_field_tag :reference_date,
                             @reference_date,
                             data: { reference_date_target: "viewDate" } %>
      <% end %>

      <% if @portfolio.present? && @portfolio.persisted? %>
        <%# Triggers a background calculation job to process performance
            metrics for the specific month selected in the interface. %>
        <%= form_with url: run_calculations_portfolio_path(@portfolio),
                      method: :post,
                      local: true,
                      id: "form-calculate",
                      data: { reference_date_target: "calcForm" },
                      class: "hidden" do |f|
        %>
          <%= hidden_field_tag :month,
                               @reference_date.strftime("%Y-%m"),
                               data: { reference_date_target: "calcMonth" } %>
        <% end %>

        <%# Submits a request to generate a downloadable monthly report
            based on the currently active reference date parameters. %>
        <%= form_with url: monthly_report_portfolio_path(@portfolio),
                      method: :get,
                      local: true,
                      data: { turbo: false, reference_date_target: "reportForm" },
                      id: "form-report",
                      class: "hidden" do |f|
        %>
          <%= hidden_field_tag :day, @reference_date.day, data: { reference_date_target: "reportDay" } %>
          <%= hidden_field_tag :month, @reference_date.month, data: { reference_date_target: "reportMonth" } %>
          <%= hidden_field_tag :year, @reference_date.year, data: { reference_date_target: "reportYear" } %>
        <% end %>
      <% end %>

      <%# Executes the view update action through the Stimulus controller
          to reload the page data for the chosen date. %>
      <%= button_tag type: "button",
                     class: "button button-outline button-small",
                     data: { action: "reference-date#view" } do %>
        <%= inline_svg_tag "icons/calendar.svg" %>
        <%= content_tag :span, "Visualizar" %>
      <% end %>

      <% if @portfolio.present? && @portfolio.persisted? %>
        <%# Initiates the performance recalculation logic for the
            selected portfolio and specific reference month. %>
        <%= button_tag type: "button",
                       class: "button button-secondary button-small",
                       data: { action: "reference-date#calculate" } do %>
          <%= inline_svg_tag "icons/refresh-cw.svg" %>
          <%= content_tag :span, "Calcular Performance" %>
        <% end %>

        <%# Requests the system to compile and export a PDF report
            containing the portfolio's financial status and history. %>
        <%= button_tag type: "button",
                       class: "button button-accent button-small",
                       data: { action: "reference-date#report" } do %>
          <%= inline_svg_tag "icons/file-attachment.svg" %>
          <%= content_tag :span, "Gerar Relatório" %>
        <% end %>
      <% end %>
    </div>
    <div class="h-7 w-[1px] bg-border"></div>
  <% end %>

  <div class="flex flex-row justify-start gap-3 items-center">
    <%= render Modules::AvatarComponent.new(user: current_user) %>
  </div>
  </div>
</div>
