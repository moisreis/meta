<%#
  Partial : _section.html.erb
  Date    : 2025-11-14
  Author  : Moisés Reis
  Package : Meta
%>

<% columns     ||= 2 %>
<% has_action  ||= false %>
<% button_route ||= nil %>
<% button_name  ||= nil %>
<% button_icon  ||= nil %>
<% button_id    ||= nil %>
<% section_title ||= nil %>
<% section_desc  ||= nil %>

<% grid_classes = {
  1 => "grid-cols-1",
  2 => "grid-cols-1 md:grid-cols-2",
  3 => "grid-cols-1 md:grid-cols-2 lg:grid-cols-3",
  4 => "grid-cols-1 md:grid-cols-2 lg:grid-cols-3 3xl:grid-cols-4",
  5 => "grid-cols-1 md:grid-cols-2 lg:grid-cols-3 3xl:grid-cols-4",
  6 => "grid-cols-1 md:grid-cols-2 lg:grid-cols-3 3xl:grid-cols-4"
}[columns] || "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3" %>

<section class="flex flex-col gap-4">

  <%# =============================================================
      Section Header — Title, Description & Action Button
      ============================================================= %>
  <div class="flex flex-row items-center justify-between">

  <%# Header %>
  <% if section_title.present? %>
    <div class="flex flex-col gap-1">
      <p class="font-mono text-body uppercase text-xs tracking-widest font-medium">
        <%= section_title %>
      </p>
      <% if section_desc.present? %>
        <p class="font-body text-muted text-sm font-normal"><%= section_desc %></p>
      <% end %>
    </div>

    <%# Note: Hidden container toggled by the info button interaction.
              Always rendered when a title is present so JS can target it
              without checking for existence first. %>
    <div class="section-desc" id="<%= section_title.parameterize %>-desc" style="display: none;">
      <%= content_tag :h2, section_desc, class: "text-sm text-muted text-left" %>
    </div>
  <% end %>

  <%# Action Button %>
  <% if has_action %>
    <%= link_to button_route, id: button_id, class: "button button-small button-outline flex-shrink-0" do %>
      <%= inline_svg_tag "icons/#{button_icon}.svg" if button_icon.present? %>
      <%= content_tag :span, button_name %>
    <% end %>
  <% end %>
  </div>

  <%# Grid %>
  <div class="grid <%= grid_classes %> gap-3">
    <%= yield %>
  </div>

</section>
