<%#
  VIEW: new.html.erb
  ACTION: ApplicationsController#new
  DESCRIPTION: Renders the page for creating a new Application record.
               Provides the form interface inside the dashboard wrapper.
  INSTANCE VARIABLES:
    - @application: [Application] A new (unsaved) Application instance.
%>
<%= render 'partials/route/dashboard/wrapper',
           page_title: "Criar Aplicação",
           page_desc: "Preencha os campos abaixo para registrar uma nova aplicação no sistema." do
%>

  <%= render "form",
             application: @application,
             button_name: "Adicionar",
             icon_name: "plus"
  %>
<% end %>
