<%#
  VIEW: edit.html.erb
  ACTION: ApplicationsController#edit
  DESCRIPTION: Renders the page for updating an existing Application record.
               Displays the edit form inside the dashboard wrapper.
  INSTANCE VARIABLES:
    - @application: [Application] The application record being edited.
%>
<%= render 'partials/route/dashboard/wrapper',
           page_title: "Editar aplicação ##{@application.id}",
           page_desc: "Atualize as informações da aplicação conforme necessário." do
%>

  <%= render "form",
             application: @application,
             button_name: "Atualizar",
             icon_name: "refresh-cw"
  %>
<% end %>
