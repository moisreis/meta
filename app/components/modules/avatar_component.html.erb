<%#
  VIEW: app/components/modules/avatar_component.html.erb
  COMPONENT: Modules::AvatarComponent

  DESCRIPTION:
  Renders a circular avatar displaying a user's initials. Acts as a fallback
  when no profile image is available.

  DEPENDENCIES:
  - initials: [String] Two-character uppercase initials derived from the component.
%>

<span data-slot="avatar"
      class="relative flex justify-center items-center h-7 w-7 shrink-0 overflow-hidden rounded-full bg-honeysuckle-300">

  <div class="flex flex-row items-center justify-center gap-0
              [&>span]:uppercase
              [&>span]:font-mono
              [&>span]:font-semibold
              [&>span]:text-3xs
              [&>span]:text-mono">

    <span><%= initials %></span>

  </div>
</span>