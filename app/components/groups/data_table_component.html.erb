<%#
  PARTIAL: app/components/groups/data_table_component.html.erb
  DESCRIPTION: Renders a configurable data table with optional toolbar actions, search reset, export, and pagination.

  LOCAL VARIABLES:
  - @columns:        [Array<Hash>] Column definitions (label, icon, description).
  - @rows:           [Enumerable] Table rows (supports pagination or plain arrays).
  - @turbo_frame_id: [String] Turbo frame identifier for async updates.
  - @search_url:     [String] URL used to reset filters/search state.
  - @q_object:       [Object, nil] Query object enabling toolbar rendering.
  - @new_path:       [String, nil] Optional path for creating new records.
  - @export_url:     [String, nil] Optional export endpoint URL.
%>

<!-- Groups::DataTableComponent -->
<% content_for :page_total, total_count.to_s %>

<div class="flex flex-col gap-3">

  <% if toolbar? %>
    <div class="flex flex-row [&>div]:flex [&>div]:flex-row [&>div]:gap-1.5 [&>div]:items-center justify-between items-center gap-6">

      <div class="justify-start">
        <%= link_to @search_url,
                    class: "button button-outline button-small",
                    data: { turbo_frame: @turbo_frame_id } do %>
          <%= render_icon("refresh-cw") %>
          <%= content_tag :span, "Limpar filtros" %>
        <% end %>

        <div class="h-4 w-[1px] bg-border"></div>

        <%= button_tag id: "openFiltersBtn",
                       class: "button button-outline button-small" do %>
          <%= render_icon("sliders-horizontal") %>
          <%= content_tag :span, "Ver filtros" %>
        <% end %>

        <% if new_path? %>
          <div class="h-4 w-[1px] bg-border"></div>
          <%= link_to @new_path,
                      class: "button button-secondary button-small",
                      data: { turbo_frame: "_top" } do %>
            <%= render_icon("plus") %>
            <%= content_tag :span, "Adicionar item" %>
          <% end %>
        <% end %>
      </div>

      <div class="justify-end">
        <% if export? %>
          <%= link_to @export_url,
                      class: "button button-secondary button-small",
                      target: "_blank",
                      data: { turbo: false } do %>
            <%= render_icon("file-chart-column") %>
            <%= content_tag :span, "Exportar" %>
          <% end %>
        <% end %>
      </div>

    </div>
  <% end %>

  <turbo-frame id="<%= @turbo_frame_id %>">
    <div class="p-3 rounded-base border border-border bg-white overflow-x-auto">
      <table class="w-full text-sm table-auto border-separate border-spacing-y-1.5
                      [&>thead]:w-full [&>tbody]:w-full
                      [&>tbody>tr]:h-9 [&>tbody>tr]:w-full
                      [&>thead>tr]:h-9">

        <thead>
          <tr class="[&>th]:whitespace-nowrap [&>th]:px-3 [&>th]:text-xs [&>th]:text-body
                       [&>th]:tracking-widest [&>th]:text-left [&>th]:uppercase
                       [&>th]:font-medium [&>th]:font-mono">
            <% @columns.each do |col| %>
              <%= render Modules::TableColumnComponent.new(
                    label:       col[:label],
                    icon:        col[:icon],
                    description: col[:description]
                  ) %>
            <% end %>
          </tr>
        </thead>

        <tbody>
          <%= content %>
        </tbody>
      </table>
    </div>
  </turbo-frame>

  <div class="flex justify-start px-3 mt-3">
    <%= helpers.paginate @rows %>
  </div>

</div>
