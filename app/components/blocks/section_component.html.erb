<%#
  PARTIAL: app/components/blocks/section_component.html.erb
  DESCRIPTION: Renders a layout section with optional title, description, action button, and configurable grid content area.

  LOCAL VARIABLES:
  - @title:        [String, nil] Optional section title.
  - @description:  [String, nil] Optional section description.
  - @action:       [Hash, nil] Optional action configuration (route/path/id/icon/label/data).
%>

<section class="flex flex-col gap-4">

  <div class="flex flex-row items-center justify-between">

    <% if title? %>
      <div class="flex flex-col gap-1">
        <p class="font-mono text-body uppercase text-xs tracking-widest font-medium">
          <%= @title %>
        </p>

        <% if description? %>
          <p class="font-body text-muted text-sm font-normal">
            <%= @description %>
          </p>
        <% end %>
      </div>

      <div class="section-desc" id="<%= description_dom_id %>" style="display: none;">
        <%= content_tag :h2, @description, class: "text-sm text-muted text-left" %>
      </div>
    <% end %>

    <% if action? %>
      <%= link_to @action[:route] || @action[:path] || "#",
                  id: @action[:id],
                  class: "button button-small button-outline flex-shrink-0",
                  data: @action[:data] do %>
        <%= render_icon(@action[:icon]) %>
        <%= content_tag :span, @action[:label] || @action[:name] %>
      <% end %>
    <% end %>

  </div>

  <div class="grid <%= grid_classes %> <%= gap_classes %> <%= separator_classes %>">
    <%= content %>
  </div>

</section>
