<%#
  PARTIAL: app/components/blocks/chart_component.html.erb
  DESCRIPTION: Renders a chart container with title, optional metadata, and empty-state fallback handling.

  LOCAL VARIABLES:
  - @title: [String] Chart title.
  - @data_source: [Array] Data set used to determine render state.
  - @id: [String, nil] Optional DOM identifier for chart targeting.
  - @meta: [String, nil] Optional metadata displayed in header.
%>

<!-- Blocks::Chart [<%= @title %>] [<%= @id %>] -->
<div class="bg-white border border-border rounded-base flex flex-col overflow-hidden"
     data-chart-id="<%= @id %>">

  <div class="flex items-center justify-between px-6 py-3 flex-shrink-0">
    <div class="flex items-center gap-3">
      <span class="size-[5px] rounded-full bg-neutral-300 flex-shrink-0"></span>
      <h3 class="font-mono text-muted uppercase text-xs tracking-widest font-medium">
        <%= @title %>
      </h3>
    </div>

    <% if @meta.present? %>
      <span class="font-mono text-muted uppercase text-3xs tracking-wide">
        <%= @meta %>
      </span>
    <% end %>
  </div>

  <div class="flex items-center justify-center h-full p-5">
    <% if data? %>
      <%= content %>
    <% else %>
      <%= content_tag :p,
                      "#{AppConstants::NO_AVAILABLE_DATA_MESSAGE}",
                      class: "font-mono text-muted uppercase text-3xs tracking-widest py-16" %>
    <% end %>
  </div>

</div>
