<div class="flex flex-col gap-6">
  <div class="flex flex-row items-center justify-start gap-3">
    <div class="flex flex-col gap-1">
      <%= tag.h2 @title, class: "font-mono text-body uppercase text-xs tracking-widest font-medium" %>
      <% if @description.present? %>
        <%= tag.p @description, class: "font-body text-muted text-sm font-normal" %>
      <% end %>
    </div>
  </div>
  <div class="grid grid-cols-1 gap-6">
    <%= content %>
  </div>
</div>