<%#
  PARTIAL: app/components/forms/fieldset_component.html.erb
  DESCRIPTION: Renders a form fieldset container with title, optional description, and grouped content area.

  LOCAL VARIABLES:
  - @title:        [String] Fieldset title (required).
  - @description:  [String, nil] Optional fieldset description.
%>

<!-- Forms::Fieldset [<%= @title %>] -->
<div class="flex flex-col gap-6">
  <div class="flex flex-row items-center justify-start gap-3">
    <div class="flex flex-col gap-1">
      <%= tag.h2 @title, class: "font-mono text-body uppercase text-xs tracking-widest font-medium" %>

      <% if @description.present? %>
        <%= tag.p @description, class: "font-body text-muted text-sm font-normal" %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6">
    <%= content %>
  </div>
</div>
