<%#
  PARTIAL: app/components/forms/input_field_component.html.erb
  DESCRIPTION: Renders a configurable form input field with optional masking, validation state, and icon support.

  LOCAL VARIABLES:
  - @f:                 [FormBuilder] Rails form builder instance.
  - @name:             [Symbol] Attribute name bound to the form object.
  - @label:            [String, nil] Optional field label.
  - @field_type:       [Symbol] Input type (e.g., :text_field, :number_field).
  - @placeholder:      [String, nil] Placeholder text.
  - @desc:             [String, nil] Help or description text.
  - @icon_name:        [String, nil] Optional trailing icon.
  - @is_inactive:      [Boolean, nil] Disabled state flag.
  - @is_half_width:    [Boolean] Layout width modifier.
  - @is_small:         [Boolean] Compact sizing flag.
  - @currency_mask:    [Boolean] Enables currency formatting mask.
  - @cnpj_mask:        [Boolean] Enables CNPJ formatting mask.
  - @bank_account_mask:[Boolean] Enables bank account formatting mask.
  - @step:             [String, nil] HTML step attribute.
  - @inputmode:        [String, nil] HTML inputmode attribute.
%>

<!-- Forms::InputField [<%= @label %>] -->
<div class="relative flex flex-col justify-start gap-1.5">

  <% if @label.present? %>
    <%= @f.label @name, @label, class: LABEL_CLASSES %>
  <% end %>

  <div class="relative <%= wrapper_width_class %>">

    <% if @currency_mask %>
      <div data-controller="currency-mask">
        <input
          type="text"
          placeholder="<%= @placeholder %>"
          class="<%= full_input_classes %>"
          inputmode="numeric"
          autocomplete="off"
          data-currency-mask-target="display"
          data-action="input->currency-mask#format"
          aria-describedby="<%= aria_describedby %>"
          aria-invalid="<%= has_error? %>"
        >
        <%= @f.hidden_field @name, data: { "currency-mask-target": "hidden" } %>
      </div>

    <% elsif @cnpj_mask %>
      <div data-controller="cnpj-mask">
        <input
          type="text"
          placeholder="<%= @placeholder || '00.000.000/0000-00' %>"
          class="<%= full_input_classes %>"
          inputmode="numeric"
          autocomplete="off"
          maxlength="18"
          data-cnpj-mask-target="display"
          data-action="input->cnpj-mask#format"
          aria-describedby="<%= aria_describedby %>"
          aria-invalid="<%= has_error? %>"
        >
        <%= @f.hidden_field @name, data: { "cnpj-mask-target": "hidden" } %>
      </div>

    <% elsif @bank_account_mask %>
      <div data-controller="bank-account-mask">
        <input
          type="text"
          placeholder="<%= @placeholder || '00000-0' %>"
          class="<%= full_input_classes %>"
          inputmode="numeric"
          autocomplete="off"
          maxlength="13"
          data-bank-account-mask-target="display"
          data-action="input->bank-account-mask#format"
          aria-describedby="<%= aria_describedby %>"
          aria-invalid="<%= has_error? %>"
        >
        <%= @f.hidden_field @name, data: { "bank-account-mask-target": "hidden" } %>
      </div>

    <% else %>
      <%= @f.send(
            @field_type,
            @name,
            placeholder: @placeholder,
            class:       full_input_classes,
            step:        @step,
            inputmode:   @inputmode,
            autocomplete: "off",
            aria: {
              describedby: aria_describedby,
              invalid:     has_error?
            }
          )
      %>
    <% end %>

    <% if @icon_name.present? %>
      <div class="absolute right-0 top-1/2 -translate-y-1/2 w-9 rounded-tr-base rounded-tb-base bg-input h-full flex items-center justify-center border border-border border-l-0">
        <%= render_icon(@icon_name, class: "size-4 stroke-muted") %>
      </div>
    <% end %>

  </div>

  <% if has_error? %>
    <%= content_tag :p,
                    error_message,
                    class: desc_classes,
                    id:    aria_describedby %>
  <% elsif @desc.present? %>
    <%= content_tag :p,
                    @desc,
                    class: desc_classes,
                    id:    aria_describedby %>
  <% end %>

</div>
