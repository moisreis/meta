#!/usr/bin/env ruby.exe
# frozen_string_literal: true

# bin/rake
#
# Entry point for executing Rake tasks within the Rails application.
#
# Boots the Rails environment, initializes Rake, and delegates
# execution to the Rake application runner.
#
# @author  Moisés Reis

# == Environment Boot =======================================================

require_relative "../config/boot"


# == Rake Initialization ====================================================

require "rake"


# == Task Execution =========================================================

Rake.application.run