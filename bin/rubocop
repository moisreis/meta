#!/usr/bin/env ruby.exe

# frozen_string_literal: true

# bin/rubocop
#
# Entry point for executing RuboCop with a fixed project configuration.
#
# Initializes the Bundler environment, injects the project-specific RuboCop
# configuration file into the CLI arguments, and delegates execution to the
# RuboCop binary.
#
# @author  Moisés Reis


# == Dependency Boot ==========================================================

require "rubygems"
require "bundler/setup"


# == CLI Configuration Injection ==============================================

# Forces the project RuboCop configuration for deterministic lint rules
# across environments and to prevent global or user-level config interference.
ARGV.unshift(
  "--config",
  File.expand_path("../.rubocop.yml", __dir__)
)


# == Execution ================================================================

load Gem.bin_path("rubocop", "rubocop")