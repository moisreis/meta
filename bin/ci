#!/usr/bin/env ruby.exe

# frozen_string_literal: true

# bin/ci
#
# Entry point for running the Continuous Integration pipeline.
#
# Boots the Rails environment, exposes the CI execution interface, and loads
# the pipeline definition from config/ci.rb.
#
# @author  Moisés Reis


# == Environment Boot ========================================================

require_relative "../config/boot"


# == CI Interface =============================================================

require "active_support/continuous_integration"

# ActiveSupport CI runner interface.
#
# @return [ActiveSupport::ContinuousIntegration]
CI = ActiveSupport::ContinuousIntegration


# == CI Configuration ========================================================

require_relative "../config/ci.rb"