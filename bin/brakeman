#!/usr/bin/env ruby.exe
# frozen_string_literal: true

# bin/brakeman
#
# Entry point for executing Brakeman security analysis.
#
# Ensures Bundler environment is loaded and delegates execution
# to the Brakeman CLI bundled with the application.
#
# @author  Moisés Reis

# == Environment Setup =======================================================

require "rubygems"
require "bundler/setup"


# == Argument Preparation ====================================================

ARGV.unshift("--ensure-latest")


# == Execution ===============================================================

load Gem.bin_path("brakeman", "brakeman")