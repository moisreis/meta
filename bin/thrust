#!/usr/bin/env ruby.exe
# frozen_string_literal: true

# bin/thruster
#
# Entry point for executing the Thruster application server CLI.
#
# Initializes the Bundler environment and delegates execution
# to the Thruster binary (thrust), which manages server runtime.
#
# @author  Moisés Reis

# == Environment Setup ======================================================

require "rubygems"
require "bundler/setup"


# == Execution ==============================================================

load Gem.bin_path("thruster", "thrust")