#!/usr/bin/env ruby.exe

# Entry point script for executing the Thruster application server CLI.
#
# This script initializes the Ruby bundler environment and delegates execution
# to the Thruster binary (thrust), which manages application server runtime.
#
# TABLE OF CONTENTS:
#
# 1. Environment Setup
# 2. Dependency Initialization
# 3. Execution
#
# @author Moisés Reis

# =============================================================
#                    1. ENVIRONMENT SETUP
# =============================================================

require "rubygems"
require "bundler/setup"

# =============================================================
#                 2. DEPENDENCY INITIALIZATION
# =============================================================

# Bundler is initialized to ensure gem dependencies are available
# before executing the application server.

# =============================================================
#                        3. EXECUTION
# =============================================================

# Launch Thruster CLI (thrust binary).
#
# This replaces the current process with the server runtime.
load Gem.bin_path("thruster", "thrust")
