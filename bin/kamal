#!/usr/bin/env ruby
# frozen_string_literal: true

# Entry point script for executing the Kamal deployment CLI.
#
# This script ensures the correct Bundler environment is loaded, validates
# the local bundler binstub, and delegates execution to the Kamal gem binary.
#
# TABLE OF CONTENTS:
#
# 1. Environment Setup
# 2. Binstub Validation
# 3. Dependency Loading
# 4. Execution
#
# @author Moisés Reis

# =============================================================
#                     1. ENVIRONMENT SETUP
# =============================================================

ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../Gemfile", __dir__)

# =============================================================
#                    2. BINSTUB VALIDATION
# =============================================================

bundle_binstub = File.expand_path("bundle", __dir__)

if File.file?(bundle_binstub)
  if File.read(bundle_binstub, 300).include?("This file was generated by Bundler")
    load(bundle_binstub)
  else
    abort("Your `bin/bundle` was not generated by Bundler, so this binstub cannot run. Replace `bin/bundle` by running `bundle binstubs bundler --force`, then run this command again.")
  end
end

# =============================================================
#                  3. DEPENDENCY LOADING
# =============================================================

require "rubygems"
require "bundler/setup"

# =============================================================
#                        4. EXECUTION
# =============================================================

# Execute the Kamal CLI binary.
#
# @return [void]
load Gem.bin_path("kamal", "kamal")
