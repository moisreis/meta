#!/usr/bin/env ruby.exe

# frozen_string_literal: true

# bin/setup
#
# Entry point for setting up and bootstrapping the development environment.
#
# Installs dependencies, prepares the database, cleans temporary files, and
# optionally starts the development server. Idempotent and safe to run
# multiple times with consistent results.
#
# @author  Moisés Reis

require "fileutils"


# == Constants ================================================================

APP_ROOT = File.expand_path("..", __dir__)


# == Helper Methods ===========================================================

# Executes a system command and raises on failure.
#
# @param args [Array<String>] command and arguments to execute.
# @return [Boolean] true if the command succeeds.
# @raise  [RuntimeError] if the command exits with a non-zero status.
def system!(*args)
  system(*args, exception: true)
end


# == Setup ====================================================================

FileUtils.chdir APP_ROOT do

  # -- Dependencies -----------------------------------------------------------

  puts "== Installing dependencies =="

  system("bundle check") || system!("bundle install")

  # -- Database ---------------------------------------------------------------

  puts "\n== Preparing database =="

  system! "bin/rails db:prepare"
  system! "bin/rails db:reset" if ARGV.include?("--reset")

  # -- Cleanup ----------------------------------------------------------------

  puts "\n== Removing old logs and tempfiles =="

  system! "bin/rails log:clear tmp:clear"

  # -- Server -----------------------------------------------------------------

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="

    STDOUT.flush

    exec "bin/dev"
  end

end