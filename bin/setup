#!/usr/bin/env ruby.exe

# Entry point script for setting up and bootstrapping the development environment.
#
# This script installs dependencies, prepares the database, cleans temporary files,
# and optionally starts the development server. It is idempotent and safe to run
# multiple times with consistent results.
#
# TABLE OF CONTENTS:
#
# 1. Environment Setup
# 2. Helper Methods
# 3. Dependency Installation
# 4. Database Preparation
# 5. Cleanup Tasks
# 6. Server Startup
#
# @author Moisés Reis

require "fileutils"

# =============================================================
#                    1. ENVIRONMENT SETUP
# =============================================================

APP_ROOT = File.expand_path("..", __dir__)

# =============================================================
#                     2. HELPER METHODS
# =============================================================

# Executes a system command and raises an exception on failure.
#
# @param args [Array<String>] Command and arguments to execute.
# @return [Boolean] true if command succeeds.
# @raise [RuntimeError] if the command fails.
def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do

  # =============================================================
  #                3. DEPENDENCY INSTALLATION
  # =============================================================

  puts "== Installing dependencies =="

  # Install gems only if needed.
  system("bundle check") || system!("bundle install")

  # =============================================================
  #                 4. DATABASE PREPARATION
  # =============================================================

  puts "\n== Preparing database =="

  system! "bin/rails db:prepare"

  # Reset database if explicitly requested via CLI flag.
  system! "bin/rails db:reset" if ARGV.include?("--reset")

  # =============================================================
  #                     5. CLEANUP TASKS
  # =============================================================

  puts "\n== Removing old logs and tempfiles =="

  system! "bin/rails log:clear tmp:clear"

  # =============================================================
  #                    6. SERVER STARTUP
  # =============================================================

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="

    STDOUT.flush

    # Replace current process with development server.
    exec "bin/dev"
  end
end
