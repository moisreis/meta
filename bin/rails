#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/rails
#
# Entry point for executing Rails command-line operations.
#
# Defines the application path, boots the Rails environment,
# and delegates execution to the Rails command dispatcher.
#
# @author  Moisés Reis

# == Application Path Resolution ============================================

APP_PATH = File.expand_path("../config/application", __dir__)


# == Environment Boot =======================================================

require_relative "../config/boot"


# == Command Execution ======================================================

require "rails/commands"