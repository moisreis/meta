#!/usr/bin/env ruby.exe
# frozen_string_literal: true

# bin/bundler-audit
#
# Entry point for executing Bundler Audit security checks.
#
# Initializes the application environment, configures default
# CLI arguments, and delegates execution to Bundler Audit.
#
# @author  Moisés Reis

# == Environment Boot =======================================================

require_relative "../config/boot"
require "bundler/audit/cli"


# == Argument Handling ======================================================

ARGV.concat %w[--config config/bundler-audit.yml] \
  if ARGV.empty? || ARGV.include?("check")


# == Execution ==============================================================

Bundler::Audit::CLI.start