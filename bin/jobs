#!/usr/bin/env ruby

# Entry point script for executing Solid Queue CLI commands.
#
# This script loads the Rails environment and starts the Solid Queue
# command-line interface for managing background job processing.
#
# TABLE OF CONTENTS:
#
# 1. Environment Boot
# 2. CLI Loading
# 3. Execution
#
# @author Moisés Reis

# =============================================================
#                     1. ENVIRONMENT BOOT
# =============================================================

require_relative "../config/environment"

# =============================================================
#                      2. CLI LOADING
# =============================================================

# Load Solid Queue command-line interface.
require "solid_queue/cli"

# =============================================================
#                        3. EXECUTION
# =============================================================

# Start Solid Queue CLI with provided arguments.
#
# @param argv [Array<String>] Command-line arguments passed to the script.
# @return [void]
SolidQueue::Cli.start(ARGV)
