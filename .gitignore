# Configures Git ignore rules for temporary, generated, sensitive, and
# environment-specific files.
#
# This file prevents local development artifacts, runtime data, compiled assets,
# and secret credentials from being committed to version control.
#
# @author Moisés Reis

# ============================================================================
# ENVIRONMENT & CONFIGURATION
# ============================================================================

/.bundle
/.env*

# ============================================================================
# LOGS & TEMPORARY FILES
# ============================================================================

/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# ============================================================================
# STORAGE & GENERATED ASSETS
# ============================================================================

/storage/*
!/storage/.keep

/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

/app/assets/builds/*
!/app/assets/builds/.keep

# ============================================================================
# ENCRYPTION & SECRET KEYS
# ============================================================================

/config/*.key
