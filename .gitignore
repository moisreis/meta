# Configures Git to ignore temporary, sensitive, and environment-specific files.
#
# This file prevents development artifacts, logs, and security keys from being
# committed to version control.
#
# TABLE OF CONTENTS:
#
# 1. Environment & Config
# 2. Logs & Temp Files
# 3. Storage & Assets
# 4. Security Keys
#
# @author Moisés Reis

# =============================================================
#                  1. ENVIRONMENT & CONFIG
# =============================================================

/.bundle
/.env*

# =============================================================
#                    2. LOGS & TEMP FILES
# =============================================================

/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# =============================================================
#                     3. STORAGE & ASSETS
# =============================================================

/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# =============================================================
#                      4. SECURITY KEYS
# =============================================================

/config/*.key
