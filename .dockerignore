# Defines Docker build context exclusion rules for the Rails application.
#
# This file prevents unnecessary, sensitive, or development-only files from
# being sent to the Docker daemon during image builds, improving build
# performance, reducing image size, and limiting exposure of local artifacts.
#
# @author Moisés Reis

# ============================================================================
# VERSION CONTROL & ENVIRONMENT
# ============================================================================

/.git/
/.gitignore
/.bundle
/.env*

# ============================================================================
# ENCRYPTION & SECRET KEYS
# ============================================================================

/config/master.key
/config/credentials/*.key

# ============================================================================
# LOGS & TEMPORARY FILES
# ============================================================================

/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

/tmp/pids/*
!/tmp/pids/.keep

# ============================================================================
# STORAGE & GENERATED ASSETS
# ============================================================================

/storage/*
!/storage/.keep

/tmp/storage/*
!/tmp/storage/.keep

/node_modules/

/app/assets/builds/*
!/app/assets/builds/.keep

/public/assets

# ============================================================================
# TOOLING & DEPLOYMENT CONFIGURATION
# ============================================================================

/.github
/.kamal
/.devcontainer

/config/deploy*.yml

/.dockerignore
/Dockerfile*
