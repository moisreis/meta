# Defines Git attribute rules for generated files, vendored dependencies,
# and encrypted credentials.
#
# This file configures repository behavior for diff handling and GitHub
# Linguist classification to improve repository readability and tooling.
#
# @author Moisés Reis

# ============================================================================
# GITHUB LINGUIST OVERRIDES
# ============================================================================

# Treat the Rails schema file as generated code.
db/schema.rb linguist-generated

# Treat vendored dependencies as third-party code.
vendor/* linguist-vendored

# ============================================================================
# ENCRYPTED CREDENTIAL DIFF HANDLING
# ============================================================================

config/credentials/*.yml.enc diff=rails_credentials
config/credentials.yml.enc diff=rails_credentials
